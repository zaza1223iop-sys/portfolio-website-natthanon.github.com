  if (c.type) badgesHtml += ' <span style="display:inline-block;font-size:12px;padding:4px 10px;border-radius:20px;background:var(--color-background-secondary);color:var(--color-text-secondary);border:0.5px solid var(--color-border-tertiary)">' + c.type + '</span>';
