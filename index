var _popupImgTab = 'url';
var _popupImgData = ''; // base64 or URL

function loadPopupSettings() {
  try {
    var s = localStorage.getItem('nn_popup_cfg');
    if (s) return JSON.parse(s);
  } catch(e) {}
  return {
    enabled: false,
    title: '',
    message: '',
    imgUrl: '',
    imgData: '',
    imgMode: 'url', // 'url' | 'file' | 'none'
    btnText: '',
    btnUrl: '',
    trigger: 'once_per_day', // 'always' | 'once_per_day' | 'once_ever'
    delay: 1
  };
}

function savePopupSettings(cfg) {
  try { localStorage.setItem('nn_popup_cfg', JSON.stringify(cfg)); } catch(e) {}
}

function shouldShowPopup(cfg) {
  if (!cfg.enabled) return false;
  if (cfg.trigger === 'always') return true;
  if (cfg.trigger === 'once_per_day') {
    var lastShown = localStorage.getItem('nn_popup_last');
    if (!lastShown) return true;
    return new Date().toDateString() !== new Date(parseInt(lastShown)).toDateString();
  }
  if (cfg.trigger === 'once_ever') {
    return !localStorage.getItem('nn_popup_seen');
  }
  return true;
}

function markPopupShown() {
  localStorage.setItem('nn_popup_last', Date.now().toString());
  localStorage.setItem('nn_popup_seen', '1');
}

function initPopup() {
  var cfg = loadPopupSettings();
  if (!shouldShowPopup(cfg)) return;
  var delay = (cfg.delay >= 0 ? cfg.delay : 1) * 1000;
  setTimeout(function() { showPopup(cfg); }, delay);
}

function showPopup(cfg) {
  if (!cfg) cfg = loadPopupSettings();
  if (!cfg.title && !cfg.message && !cfg.imgUrl && !cfg.imgData) return;

  // Image
  var imgWrap = document.getElementById('popup-img-wrap');
  var imgSrc = cfg.imgMode === 'file' ? cfg.imgData : (cfg.imgMode === 'url' ? cfg.imgUrl : '');
  if (imgSrc && cfg.imgMode !== 'none') {
    imgWrap.innerHTML = '<img src="'+imgSrc+'" alt="" onerror="this.parentNode.innerHTML=\'<div class=popup-img-placeholder><i class=\\\"ti ti-speakerphone\\\"></i></div>\'">';
    imgWrap.style.display = 'flex';
  } else if (cfg.imgMode === 'none' || (!cfg.imgUrl && !cfg.imgData)) {
    imgWrap.style.display = 'none';
  } else {
    imgWrap.innerHTML = '<div class="popup-img-placeholder"><i class="ti ti-speakerphone"></i></div>';
    imgWrap.style.display = 'flex';
  }

  // Title + message
  document.getElementById('popup-title').textContent = cfg.title || '';
  document.getElementById('popup-message').textContent = cfg.message || '';

  // Button
  var linkBtn = document.getElementById('popup-link-btn');
  if (cfg.btnText && cfg.btnUrl) {
    linkBtn.style.display = 'inline-flex';
    linkBtn.href = cfg.btnUrl;
    document.getElementById('popup-link-text').textContent = cfg.btnText;
  } else {
    linkBtn.style.display = 'none';
  }

  document.getElementById('popup-overlay').classList.add('show');
  document.body.style.overflow = 'hidden';
  markPopupShown();
}

function closePopup() {
  document.getElementById('popup-overlay').classList.remove('show');
  document.body.style.overflow = '';
}

function popupDontShowToday() {
  // mark as seen for today regardless of trigger
  localStorage.setItem('nn_popup_last', Date.now().toString());
  localStorage.setItem('nn_popup_seen', '1');
  closePopup();
}

function resetPopupHistory() {
  localStorage.removeItem('nn_popup_last');
  localStorage.removeItem('nn_popup_seen');
  showToast('รีเซ็ตประวัติ Popup แล้ว');
}

function testPopupPreview() {
  // Save current form data temporarily and show
  var cfg = buildPopupCfgFromForm();
  showPopup(cfg);
}

function buildPopupCfgFromForm() {
  return {
    enabled: document.getElementById('adm-popup-enabled').checked,
    title: document.getElementById('adm-popup-title').value.trim(),
    message: document.getElementById('adm-popup-message').value.trim(),
    imgUrl: document.getElementById('adm-popup-img-url').value.trim(),
    imgData: _popupImgData,
    imgMode: _popupImgTab,
    btnText: document.getElementById('adm-popup-btn-text').value.trim(),
    btnUrl: document.getElementById('adm-popup-btn-url').value.trim(),
    trigger: document.getElementById('adm-popup-trigger').value,
    delay: parseFloat(document.getElementById('adm-popup-delay').value) || 0
  };
}

function loadPopupIntoAdmin() {
  var cfg = loadPopupSettings();
  document.getElementById('adm-popup-enabled').checked = !!cfg.enabled;
  document.getElementById('adm-popup-title').value = cfg.title || '';
  document.getElementById('adm-popup-message').value = cfg.message || '';
  document.getElementById('adm-popup-img-url').value = cfg.imgUrl || '';
  document.getElementById('adm-popup-btn-text').value = cfg.btnText || '';
  document.getElementById('adm-popup-btn-url').value = cfg.btnUrl || '';
  document.getElementById('adm-popup-trigger').value = cfg.trigger || 'once_per_day';
  document.getElementById('adm-popup-delay').value = cfg.delay !== undefined ? cfg.delay : 1;
  _popupImgData = cfg.imgData || '';
  _popupImgTab = cfg.imgMode || 'url';
  switchPopupImgTab(_popupImgTab, true);
  // Show preview if has image
  var imgSrc = cfg.imgMode === 'file' ? cfg.imgData : cfg.imgUrl;
  var prev = document.getElementById('adm-popup-img-preview');
  if (imgSrc && cfg.imgMode !== 'none') {
    prev.src = imgSrc; prev.style.display = 'block';
    document.getElementById('adm-popup-img-clear').style.display = 'inline-block';
  } else {
    prev.style.display = 'none';
    document.getElementById('adm-popup-img-clear').style.display = 'none';
  }
}

function savePopupFromAdmin() {
  var cfg = buildPopupCfgFromForm();
  savePopupSettings(cfg);
}

function switchPopupImgTab(tab, silent) {
  _popupImgTab = tab;
  ['url','file','none'].forEach(function(t) {
    var btn = document.getElementById('padm-tab-'+t);
    var panel = document.getElementById('padm-panel-'+t);
    if (btn) btn.classList.toggle('active', t === tab);
    if (panel) panel.classList.toggle('active', t === tab);
  });
  if (!silent) {
    var prev = document.getElementById('adm-popup-img-preview');
    prev.style.display = 'none';
    document.getElementById('adm-popup-img-clear').style.display = 'none';
    _popupImgData = '';
  }
}

function previewPopupImgUrl(url) {
  var prev = document.getElementById('adm-popup-img-preview');
  var clearBtn = document.getElementById('adm-popup-img-clear');
  if (!url.trim()) { prev.style.display = 'none'; clearBtn.style.display = 'none'; return; }
  prev.src = url.trim();
  prev.style.display = 'block';
  clearBtn.style.display = 'inline-block';
  prev.onerror = function() { prev.style.display = 'none'; clearBtn.style.display = 'none'; prev.onerror=null; };
}

function handlePopupImgFile(input) {
  var file = input.files[0]; if (!file) return;
  compressImage(file, function(dataUrl) {
    _popupImgData = dataUrl;
    var prev = document.getElementById('adm-popup-img-preview');
    prev.src = dataUrl; prev.style.display = 'block';
    document.getElementById('adm-popup-img-clear').style.display = 'inline-block';
  });
}

function clearPopupImg() {
  _popupImgData = '';
  document.getElementById('adm-popup-img-url').value = '';
  document.getElementById('adm-popup-img-file').value = '';
  var prev = document.getElementById('adm-popup-img-preview');
  prev.src = ''; prev.style.display = 'none';
  document.getElementById('adm-popup-img-clear').style.display = 'none';
}

// Close popup on Escape key
document.addEventListener('keydown', function(e) {
  if (e.key === 'Escape') {
    var po = document.getElementById('popup-overlay');
    if (po && po.classList.contains('show')) closePopup();
  }
});

