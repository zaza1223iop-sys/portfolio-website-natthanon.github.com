// ===== ImgBB Upload =====
function handleImgBBDrop(e) {
  e.preventDefault();
  document.getElementById('imgbb-drop-zone').style.borderColor = '';
  var file = e.dataTransfer.files[0];
  if (file && file.type.startsWith('image/')) uploadToImgBB(file);
}

function uploadToImgBB(file) {
  var key = getImgBBKey();
  if (!key) {
    showToast('กรุณาตั้งค่า ImgBB API Key ก่อน (ตั้งค่าระบบ/หน้าบ้าน)');
    document.getElementById('imgbb-no-key-warn').style.display = 'block';
    return;
  }
  // บีบอัดก่อนอัปโหลด
  compressImage(file, function(dataUrl) {
    // แปลง dataUrl → Blob → FormData
    var byteStr = atob(dataUrl.split(',')[1]);
    var arr = new Uint8Array(byteStr.length);
    for (var i = 0; i < byteStr.length; i++) arr[i] = byteStr.charCodeAt(i);
    var blob = new Blob([arr], {type: 'image/jpeg'});

    var formData = new FormData();
    formData.append('image', blob, 'cert.jpg');
    formData.append('key', key);

    // แสดง progress
    var wrap = document.getElementById('imgbb-progress-wrap');
    var bar  = document.getElementById('imgbb-progress-bar');
    var lbl  = document.getElementById('imgbb-progress-label');
    wrap.style.display = 'block';
    bar.style.width = '0%';
    lbl.textContent = 'กำลังอัปโหลดไป ImgBB...';

    // Animate progress (ไม่ได้ track จริง แต่ดูดีขึ้น)
    var pct = 0;
    var timer = setInterval(function() {
      pct = Math.min(pct + 10, 85);
      bar.style.width = pct + '%';
    }, 200);

    fetch('https://api.imgbb.com/1/upload', { method: 'POST', body: formData })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        clearInterval(timer);
        if (data.success) {
          bar.style.width = '100%';
          bar.style.background = '#3B6D11';
          lbl.textContent = '✅ อัปโหลดสำเร็จ! URL พร้อมใช้งาน';
          var imgUrl = data.data.display_url || data.data.url;
          var prev = document.getElementById('f-preview');
          prev.src = imgUrl;
          prev.style.display = 'block';
          prev.dataset.driveUrl = imgUrl; // ใช้ field เดิม เก็บ URL ใดก็ได้ที่ไม่ใช่ base64
          var hint = document.getElementById('f-img-size-hint');
          hint.textContent = '☁️ รูปอยู่บน ImgBB — ไม่กินพื้นที่ localhost';
          hint.style.color = '#185FA5';
          document.getElementById('f-img-clear-btn').style.display = 'inline-flex';
          // อัปเดต drop zone
          document.getElementById('imgbb-upload-text').textContent = 'อัปโหลดสำเร็จ! คลิกเพื่อเปลี่ยนรูป';
        } else {
          clearInterval(timer);
          bar.style.background = '#c0392b';
          bar.style.width = '100%';
          var msg = (data.error && data.error.message) ? data.error.message : 'ไม่ทราบสาเหตุ';
          lbl.textContent = '❌ อัปโหลดไม่สำเร็จ: ' + msg;
          if (msg.toLowerCase().indexOf('invalid') > -1 || msg.toLowerCase().indexOf('key') > -1) {
            lbl.textContent += ' — ตรวจสอบ API Key';
          }
        }
      })
      .catch(function(err) {
        clearInterval(timer);
        bar.style.background = '#c0392b';
        bar.style.width = '100%';
        lbl.textContent = '❌ เชื่อมต่อไม่ได้: ' + err.message;
      });
  });
}

