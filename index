  document.getElementById('form-card-title').innerHTML='<i class="ti ti-edit" style="color:#185FA5"></i> แก้ไขเกียรติบัตร';
  // Load privacy
  selectPrivacy(c.privacy || 'public');
  navigate('add');
}

// 3. ป้องกัน LocalStorage เต็มด้วยการลดขนาดและบีบอัดรูปภาพด้วย Canvas
function getStorageUsageKB() {
  var total = 0;
  try {
    for (var k in localStorage) {
      if (localStorage.hasOwnProperty(k)) total += (localStorage[k].length * 2);
    }
  } catch(e) {}
  return Math.round(total / 1024);
}

function updateStorageBar() {
  var used = getStorageUsageKB();
  var limit = 5120; // ~5MB
  var pct = Math.min(100, Math.round(used / limit * 100));
  var bar = document.getElementById('storage-bar-fill');
  var label = document.getElementById('storage-bar-label');
  if (!bar || !label) return;
  bar.style.width = pct + '%';
  bar.style.background = pct > 80 ? '#c0392b' : pct > 60 ? '#E8B84B' : '#3B6D11';
  label.textContent = 'พื้นที่ใช้ไป: ' + used + ' KB / ~5120 KB (' + pct + '%)';
}

function compressImage(file, callback) {
  var reader = new FileReader();
  reader.onload = function(e){
    var imgObj = new Image();
    imgObj.onload = function() {
      var canvas = document.createElement('canvas');
      var ctx = canvas.getContext('2d');
      // ลดขนาดสูงสุดเหลือ 800px เพื่อให้ภาพคมชัดขึ้น
      var MAX_SIZE = 800;
      var width = imgObj.width;
      var height = imgObj.height;
      if (width > height) {
        if (width > MAX_SIZE) { height = Math.round(height * MAX_SIZE / width); width = MAX_SIZE; }
      } else {
        if (height > MAX_SIZE) { width = Math.round(width * MAX_SIZE / height); height = MAX_SIZE; }
      }
      canvas.width = width;
      canvas.height = height;
      ctx.drawImage(imgObj, 0, 0, width, height);
      // บีบอัดเป็น JPEG 82% Quality (คมชัดขึ้น)
      var dataUrl = canvas.toDataURL('image/jpeg', 0.82);
      callback(dataUrl);
    };
    imgObj.src = e.target.result;
  };
  reader.readAsDataURL(file);
}

function previewFile(input){
  var file=input.files[0];if(!file)return;
  compressImage(file, function(dataUrl) {
    var sizeKB = Math.round(dataUrl.length * 0.75 / 1024);
    var imgEl = document.getElementById('f-preview');
    imgEl.src = dataUrl;
    imgEl.style.display = 'block';
    // แสดงขนาดหลังบีบ
    var sizeHint = document.getElementById('f-img-size-hint');
    if (sizeHint) {
      sizeHint.textContent = '📦 ขนาดรูปหลังบีบอัด: ' + sizeKB + ' KB';
      sizeHint.style.color = sizeKB > 80 ? '#c0392b' : '#3B6D11';
    }
    var clearBtn = document.getElementById('f-img-clear-btn');
    if (clearBtn) clearBtn.style.display = 'inline-flex';
    updateStorageBar();
  });
}

