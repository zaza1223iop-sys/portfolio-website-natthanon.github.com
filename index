}
.pub-detail-hero-placeholder {
  width: 100%;
  height: 180px;
  background: linear-gradient(135deg, #1a2744 0%, #2d3f6b 100%);
  border-radius: 20px 20px 0 0;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pub-detail-hero-placeholder i { font-size: 60px; color: rgba(255,255,255,0.18); }

.pub-detail-close {
  position: absolute;
  top: 14px;
  right: 14px;
  width: 34px;
  height: 34px;
  border-radius: 50%;
  background: rgba(0,0,0,0.45);
  backdrop-filter: blur(4px);
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  cursor: pointer;
  color: #fff;
  font-size: 16px;
  transition: background 0.15s;
  z-index: 10;
}
.pub-detail-close:hover { background: rgba(0,0,0,0.65); }

/* ===== LIGHTBOX (ดูภาพเต็มจอ) ===== */
