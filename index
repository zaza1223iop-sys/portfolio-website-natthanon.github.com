    +'<button class="btn btn-navy" onclick="editCert('+id+')"><i class="ti ti-edit"></i> แก้ไข</button>'
    +((c.privacy||'public') !== 'private' ? '<button class="btn btn-ghost" onclick="openShareModal('+id+');closeModal()"><i class="ti ti-share"></i> แชร์ลิงก์</button>' : '')
