function prefillFromOcr(info) {
  closeOcrModal();
  setTimeout(function(){
    navigate('add');
    // กรอกข้อมูลที่อ่านได้อัตโนมัติ
    var nameEl = document.getElementById('f-name');
    var orgEl = document.getElementById('f-org');
    var noteEl = document.getElementById('f-note');
    if (nameEl && info.name) nameEl.value = info.name;
    if (orgEl && info.org) orgEl.value = info.org;
    if (noteEl) {
      var parts = [];
      if (info.competition) parts.push(info.competition);
      if (info.award) parts.push(info.award);
      if (parts.length) noteEl.value = parts.join(' · ');
    }
    // ปีจาก OCR → แปลงเป็น input date (ค.ศ.)
    if (info.year) {
      var y = parseInt(info.year.replace(/[^\d]/g,''));
      if (y > 2500) y = y - 543; // แปลง พ.ศ. → ค.ศ.
      if (y > 1900 && y < 2200) {
        var dateEl = document.getElementById('f-date');
        if (dateEl) dateEl.value = y + '-01-01';
      }
    }
    showToast('✅ กรอกข้อมูลจากเกียรติบัตรอัตโนมัติแล้ว');
  }, 300);
}
