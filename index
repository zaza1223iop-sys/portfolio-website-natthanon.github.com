// Parse ข้อความ OCR ดิบ → structured info
function parseOcrText(text) {
  var lines = text.split('\n').map(function(l){ return l.trim(); }).filter(Boolean);
  var info = { name:'', person:'', org:'', year:'', competition:'', award:'', keywords:[] };

  // หาปี
  var yearMatch = text.match(/\b(25\d\d|19\d\d|20\d\d)\b/g);
  if (yearMatch) {
    yearMatch.forEach(function(y) {
      var num = parseInt(y);
      if (num >= 2500 && num <= 2600 && !info.year) info.year = String(num);
      else if (num >= 1990 && num <= 2100 && !info.year) info.year = String(num);
    });
  }

  // ระดับรางวัล
  var awardKws = ['ชนะเลิศ','รองชนะเลิศ','อันดับ 1','อันดับ 2','อันดับ 3','เหรียญทอง','เหรียญเงิน','เหรียญทองแดง','ชมเชย','เข้าร่วม','ผ่าน','gold','silver','bronze','first place','second place','winner'];
  awardKws.forEach(function(kw) {
    if (text.toLowerCase().indexOf(kw.toLowerCase()) > -1 && !info.award) info.award = kw;
  });

  // หน่วยงาน
  var orgKws = ['กระทรวง','สำนักงาน','เขตพื้นที่','โรงเรียน','มหาวิทยาลัย','สมาคม','สพม','สพป','กสทช','สสวท','ministry','university','association','department','institute','school','college'];
  lines.forEach(function(line) {
    orgKws.forEach(function(kw) {
      if (line.toLowerCase().indexOf(kw.toLowerCase()) > -1 && !info.org) info.org = line;
    });
  });

  // ชื่อคน
  var personRe = /^(นาย|นาง|นางสาว|เด็กชาย|เด็กหญิง|ด\.ช\.|ด\.ญ\.|Mr\.|Ms\.|Miss|Mrs\.)\s*.+/i;
  lines.forEach(function(line) {
    if (personRe.test(line) && !info.person) info.person = line;
  });

  // ชื่อการแข่งขัน
  lines.forEach(function(line) {
    if (/การแข่งขัน|competition|contest|olympiad|โอลิมปิก|ประกวด/i.test(line) && !info.competition) info.competition = line;
  });

  // ชื่อรางวัล
  var nameCandidates = lines.filter(function(l) { return /รางวัล|เกียรติบัตร|certificate|award/i.test(l); });
  info.name = nameCandidates[0] || lines[0] || '';

  // Keywords
  var seen = {};
  lines.forEach(function(line) {
    line.split(/[\s,\/\(\)]+/).forEach(function(w) {
      if (w.length > 4 && !/^\d+$/.test(w) && !seen[w]) { seen[w] = true; info.keywords.push(w); }
    });
  });
  info.keywords = info.keywords.slice(0, 10);

  return info;
}

function runOcrScan() {
  if (!_ocrImageDataUrl) { showToast('กรุณาเลือกรูปก่อน'); return; }

  var btn = document.getElementById('ocr-scan-btn');
  btn.disabled = true;
  document.getElementById('ocr-spinner').style.display = 'block';
  document.getElementById('ocr-btn-icon').style.display = 'none';
  document.getElementById('ocr-btn-label').textContent = 'กำลังสแกน...';
  document.getElementById('ocr-result-section').style.display = 'none';
  setOcrStatus('loading', '⏳ กำลังส่งรูปไป OCR.space...');

  function resetBtn() {
    btn.disabled = false;
    document.getElementById('ocr-spinner').style.display = 'none';
    document.getElementById('ocr-btn-icon').style.display = '';
    document.getElementById('ocr-btn-label').textContent = '🔍 สแกนและค้นหา';
  }

  // แปลง dataURL → Blob → FormData
  var base64 = _ocrImageDataUrl.split(',')[1];
  var mime = (_ocrImageDataUrl.match(/^data:([^;]+)/) || [])[1] || 'image/jpeg';
  var byteStr = atob(base64);
  var arr = new Uint8Array(byteStr.length);
  for (var i = 0; i < byteStr.length; i++) arr[i] = byteStr.charCodeAt(i);
  var blob = new Blob([arr], { type: mime });

  var fd = new FormData();
  fd.append('apikey', OCR_SPACE_KEY);
  fd.append('language', 'tha');          // ภาษาไทยก่อน
  fd.append('isOverlayRequired', 'false');
  fd.append('detectOrientation', 'true');
  fd.append('scale', 'true');
  fd.append('OCREngine', '2');           // Engine 2 แม่นยำกว่าสำหรับไทย
  fd.append('file', blob, 'cert.jpg');

  fetch(OCR_SPACE_URL, { method: 'POST', body: fd })
    .then(function(r) {
      if (!r.ok) throw new Error('HTTP ' + r.status);
      return r.json();
    })
    .then(function(data) {
      if (data.IsErroredOnProcessing) {
        throw new Error(data.ErrorMessage || 'OCR.space error');
      }
      var parsed = data.ParsedResults || [];
      var rawText = parsed.map(function(p){ return p.ParsedText || ''; }).join('\n');
      _ocrRawText = rawText;

      if (!rawText.trim()) {
        // ลองใหม่ด้วยภาษา eng ถ้าไทยไม่ได้ผล
        setOcrStatus('loading', '⏳ ลองสแกนด้วยภาษาอังกฤษ...');
        var fd2 = new FormData();
        fd2.append('apikey', OCR_SPACE_KEY);
        fd2.append('language', 'eng');
        fd2.append('isOverlayRequired', 'false');
        fd2.append('detectOrientation', 'true');
        fd2.append('scale', 'true');
        fd2.append('OCREngine', '2');
        fd2.append('file', blob, 'cert.jpg');
        return fetch(OCR_SPACE_URL, { method: 'POST', body: fd2 })
          .then(function(r2){ return r2.json(); })
          .then(function(data2){
            var parsed2 = data2.ParsedResults || [];
            rawText = parsed2.map(function(p){ return p.ParsedText || ''; }).join('\n');
            _ocrRawText = rawText;
            return rawText;
          });
      }
      return rawText;
    })
    .then(function(rawText) {
      if (!rawText || !rawText.trim()) {
        setOcrStatus('error', '❌ ไม่พบข้อความในรูป — ลองใช้รูปที่ชัดขึ้น ตัวหนังสือไม่เอียง และแสงสว่างเพียงพอ');
        resetBtn();
        return;
      }
      var info = parseOcrText(rawText);
      setOcrStatus('success', '✅ สแกนสำเร็จ! กำลังค้นหาในฐานข้อมูล...');
      renderOcrExtracted(info);
      var matches = searchOcrInDB(info);
      renderOcrMatches(matches, info);
      document.getElementById('ocr-result-section').style.display = 'block';
      if (matches.length > 0) {
        setOcrStatus('success', '✅ สแกนสำเร็จ! พบผลงานที่ตรงกัน ' + matches.length + ' รายการ');
      } else {
        setOcrStatus('success', '✅ สแกนสำเร็จ แต่ยังไม่พบผลงานที่ตรงกันในระบบ');
      }
      resetBtn();
    })
    .catch(function(err) {
      setOcrStatus('error', '❌ เกิดข้อผิดพลาด: ' + (err.message || err));
      console.error('OCR.space error:', err);
      resetBtn();
    });
}

function renderOcrExtracted(info) {
  var fields = [
    { key: 'ชื่อรางวัล', val: info.name },
    { key: 'ผู้รับ', val: info.person },
    { key: 'การแข่งขัน', val: info.competition },
    { key: 'ระดับรางวัล', val: info.award },
    { key: 'หน่วยงาน', val: info.org },
    { key: 'ปี', val: info.year },
  ];
  var html = fields.filter(function(f){ return f.val && f.val.trim(); }).map(function(f){
    return '<div class="ocr-info-row">'
      + '<div class="ocr-info-key">' + f.key + '</div>'
      + '<div class="ocr-info-val">' + escapeHtml(f.val) + '</div>'
      + '</div>';
  }).join('');

  if (info.keywords && info.keywords.length > 0) {
    html += '<div class="ocr-info-row">'
      + '<div class="ocr-info-key">Keywords</div>'
      + '<div class="ocr-info-val" style="display:flex;flex-wrap:wrap;gap:4px">'
      + info.keywords.map(function(k){
          return '<span style="background:#EFF6FF;color:#1D4ED8;border-radius:20px;padding:2px 8px;font-size:11px;font-weight:600">' + escapeHtml(k) + '</span>';
        }).join('')
      + '</div></div>';
  }

  document.getElementById('ocr-extracted-info').innerHTML = html || '<div style="color:var(--color-text-tertiary);font-size:13px">ไม่พบข้อมูลที่ชัดเจน</div>';
}

function searchOcrInDB(info) {
  if (!db || !db.length) return [];

  // เตรียม keywords สำหรับค้นหา
  var keywords = [];
  if (info.name) keywords = keywords.concat(info.name.toLowerCase().split(/\s+/));
  if (info.competition) keywords = keywords.concat(info.competition.toLowerCase().split(/\s+/));
  if (info.award) keywords = keywords.concat(info.award.toLowerCase().split(/\s+/));
  if (info.org) keywords.push(info.org.toLowerCase());
  if (info.keywords) info.keywords.forEach(function(k){ keywords.push(k.toLowerCase()); });

  // กรอง keyword สั้นเกิน 2 ตัวอักษรออก
  keywords = keywords.filter(function(k){ return k.length > 2; });

  var year = info.year ? info.year.replace(/[^\d]/g,'') : '';
  // แปลง พ.ศ. → ค.ศ. และกลับ
  var yearVariants = [year];
  if (year.length === 4) {
    var y = parseInt(year);
    yearVariants.push(String(y > 2500 ? y - 543 : y + 543));
  }

  // Scoring
  var results = db.map(function(cert) {
    var text = [cert.name, cert.note, cert.org, cert.type].join(' ').toLowerCase();
    var certYear = cert.date ? cert.date.slice(0, 4) : '';
    // แปลงปีเกียรติบัตรเป็น พ.ศ.
    var certYearTH = certYear.length === 4 ? String(parseInt(certYear) + 543) : certYear;
    var certYearVariants = [certYear, certYearTH];

    var score = 0;
    keywords.forEach(function(kw) {
      if (kw.length > 3 && text.indexOf(kw) > -1) score += 2;
      else if (text.indexOf(kw) > -1) score += 1;
    });
    // Bonus ปีตรง
    yearVariants.forEach(function(y) {
      if (y && certYearVariants.indexOf(y) > -1) score += 3;
    });

    return { cert: cert, score: score };
  });

  return results
    .filter(function(r){ return r.score >= 2; })
    .sort(function(a, b){ return b.score - a.score; })
    .slice(0, 5)
    .map(function(r){ return r.cert; });
}

function renderOcrMatches(matches, info) {
  var countEl = document.getElementById('ocr-match-count');
  var listEl = document.getElementById('ocr-match-list');

  countEl.textContent = matches.length + ' รายการ';

  if (!matches.length) {
    listEl.innerHTML = '<div class="ocr-no-match">'
      + '<i class="ti ti-search-off"></i>'
      + '<div style="font-size:13px;margin-bottom:6px">ไม่พบผลงานที่ตรงกัน</div>'
      + '<div style="font-size:11px">ลองเพิ่มเกียรติบัตรนี้ใหม่ในระบบ</div>'
      + '<button class="btn btn-gold" style="margin-top:10px;font-size:12px;padding:7px 14px" onclick="prefillFromOcr(' + JSON.stringify(info).replace(/"/g,'&quot;') + ')"><i class="ti ti-plus"></i> เพิ่มเกียรติบัตรนี้</button>'
      + '</div>';
    return;
  }

  listEl.innerHTML = matches.map(function(c) {
    var thumb = c.image
      ? '<img src="' + c.image + '" alt="">'
      : '<i class="ti ti-certificate" style="font-size:22px;color:rgba(255,255,255,0.25)"></i>';
    return '<div class="ocr-match-card" onclick="openOcrMatchDetail(\'' + c.id + '\')">'
      + '<div class="ocr-match-thumb">' + thumb + '</div>'
      + '<div class="ocr-match-info">'
      + '<div class="ocr-match-name">' + escapeHtml(c.name) + '</div>'
      + '<div class="ocr-match-meta">'
      + (c.type ? '<span>' + escapeHtml(c.type) + '</span>' : '')
      + (c.level ? ' · <span>' + escapeHtml(c.level) + '</span>' : '')
      + (c.date ? ' · ' + formatDate(c.date) : '')
      + '</div>'
      + '</div>'
      + '<div class="ocr-match-score">⭐ ' + (getLevelScore(c.level) || 0) + '</div>'
      + '</div>';
  }).join('');
}

