      localStorage.setItem('nn_imgbb_key', key);
      document.getElementById('adm-imgbb-status').textContent = '✅ บันทึก API Key แล้ว — พร้อมใช้งาน';
      document.getElementById('adm-imgbb-status').style.color = '#3B6D11';
      showToast('บันทึก ImgBB API Key แล้ว');
    } else {
      localStorage.removeItem('nn_imgbb_key');
      document.getElementById('adm-imgbb-status').textContent = '⚠️ ลบ API Key แล้ว — ระบบจะไม่อัปโหลด ImgBB';
      document.getElementById('adm-imgbb-status').style.color = '#c0392b';
    }
  } catch(e) { showToast('บันทึกไม่ได้'); }
}
function toggleImgBBKeyVisibility() {
