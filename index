function getPubFiltered() {
  var q = (document.getElementById('pub-search').value || '').toLowerCase();
  var ft = document.getElementById('pub-f-type').value;
  var fl = document.getElementById('pub-f-level').value;
  var fy = document.getElementById('pub-f-year').value;
  return db.filter(function(c){
    // Only show public and link-visible certs in public view
    if (c.privacy === 'private') return false;
    return (!q || c.name.toLowerCase().includes(q) || (c.org||'').toLowerCase().includes(q))
      && (!ft || c.type === ft)
      && (!fl || c.level === fl)
      && (!fy || (c.date||'').startsWith(fy));
  }).sort(function(a,b){ return new Date(b.date) - new Date(a.date); });
}

