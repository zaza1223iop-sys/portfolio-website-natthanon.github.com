function renderDashboard(){
  var total=db.length;
  var totalScore=db.reduce(function(s,c){return s+(c.score||0);},0);
  document.getElementById('st-total').textContent=total;
  document.getElementById('st-score').textContent=totalScore;
  
  // 4. แก้ไขการคำนวณ ระดับสูงสุด โดยดูจากคะแนนแทนลำดับอาเรย์
  var topLevel='-';
  if (db.length > 0) {
      var highestCert = db.reduce(function(prev, current) {
          return (prev.score || 0) > (current.score || 0) ? prev : current;
      });
      topLevel = highestCert.level;
  }
  document.getElementById('st-top').textContent=topLevel;

  var years=db.map(function(c){return c.date?parseInt(c.date.slice(0,4)):0;}).filter(Boolean);
  document.getElementById('st-year').textContent=years.length?(Math.max.apply(null,years)+543):'-';

  var levelCount={};C.levels.forEach(function(l){levelCount[l]=0;});
  db.forEach(function(c){if(levelCount[c.level]!==undefined)levelCount[c.level]++;});
  var maxLv=Math.max.apply(null,Object.values(levelCount).concat([1]));
  document.getElementById('dash-level-chart').innerHTML=C.levels.map(function(l){
    var pct=Math.round(levelCount[l]/maxLv*100);
    return '<div class="bar-row"><span class="bar-label">'+l+'</span>'
      +'<div class="bar-wrap"><div class="bar-fill" style="width:'+pct+'%"></div></div>'
      +'<span class="bar-val">'+levelCount[l]+'</span></div>';
  }).join('');

  var typeColors=['#1a2744','#E8B84B','#185FA5','#3B6D11','#B8860B','#993556'];
  var typeCount={};C.types.forEach(function(t){typeCount[t]=0;});
  db.forEach(function(c){if(typeCount[c.type]!==undefined)typeCount[c.type]++;});
  var canvas=document.getElementById('pie-canvas');var ctx=canvas.getContext('2d');
  ctx.clearRect(0,0,110,110);
  var vals=C.types.map(function(t){return typeCount[t];});
  var total2=vals.reduce(function(a,b){return a+b;},0);
  var startAngle=-Math.PI/2;
  if(total2>0){vals.forEach(function(v,i){var a=2*Math.PI*v/total2;ctx.beginPath();ctx.moveTo(55,55);ctx.arc(55,55,48,startAngle,startAngle+a);ctx.closePath();ctx.fillStyle=typeColors[i%typeColors.length];ctx.fill();startAngle+=a;});}
  else{ctx.beginPath();ctx.arc(55,55,48,0,2*Math.PI);ctx.fillStyle='rgba(0,0,0,0.06)';ctx.fill();}
  document.getElementById('pie-legend').innerHTML=C.types.map(function(t,i){
    return '<div class="legend-row"><div class="legend-dot" style="background:'+typeColors[i%typeColors.length]+'"></div><span class="legend-name">'+t+'</span><span class="legend-num">'+typeCount[t]+'</span></div>';
  }).join('');

  var recent=db.slice(0,6);
  var rc=document.getElementById('dash-recent');
  var re=document.getElementById('dash-empty');
  if(!recent.length){rc.innerHTML='';re.style.display='block';return;}
  re.style.display='none';
  rc.innerHTML='<div style="display:grid;grid-template-columns:repeat(auto-fill,minmax(180px,1fr));gap:10px">'+recent.map(function(c){
    return '<div style="display:flex;align-items:center;gap:8px;padding:9px;border:0.5px solid var(--color-border-tertiary);border-radius:8px;cursor:pointer" onclick="navigate(\'certificates\')">'
