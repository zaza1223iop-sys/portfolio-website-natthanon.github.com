<script>
var C={
  types:['แข่งขัน','อบรม','จิตอาสา','อื่นๆ'],
  levels:['นานาชาติ','ชาติ','ภาค','จังหวัด','เทศบาล','สถานศึกษา'],
  awards:['ชนะเลิศ (อันดับ 1)','รองชนะเลิศอันดับ 1','รองชนะเลิศอันดับ 2','รางวัลชมเชย','เข้าร่วม / ผ่าน'],
  scores:{นานาชาติ:100,ชาติ:80,ภาค:60,จังหวัด:40,เทศบาล:20,สถานศึกษา:10}
};

var sortMode='new';
var db=[];

function loadState(){
  try{
    var s=localStorage.getItem('nn_cfg');
    if(s){var cfg=JSON.parse(s);C.types=cfg.types||C.types;C.levels=cfg.levels||C.levels;C.awards=cfg.awards||C.awards;C.scores=cfg.scores||C.scores;}
    var d=localStorage.getItem('nn_certs');
    if(d)db=JSON.parse(d);
  }catch(e){}
}
function saveCfg(){localStorage.setItem('nn_cfg',JSON.stringify({types:C.types,levels:C.levels,awards:C.awards,scores:C.scores}));}
function saveDB(){
  try {
    localStorage.setItem('nn_certs',JSON.stringify(db));
  } catch(e) {
    alert("พื้นที่เก็บข้อมูลเต็ม (Quota Exceeded) กรุณาลบเกียรติบัตรบางใบก่อน");
  }
}

function navigate(page){
  document.querySelectorAll('.page').forEach(function(p){p.classList.remove('active');});
  document.querySelectorAll('.nav-item').forEach(function(n){n.classList.remove('active');});
  document.getElementById('page-'+page).classList.add('active');
  var pageMap={dashboard:'title_dashboard',certificates:'title_certificates',add:'title_add',ranking:'title_ranking',settings:'title_settings',export:'title_export',ebooks:'title_ebooks',resume:'Resume'};
  document.getElementById('page-title').textContent=t(pageMap[page]||page);
  
  // 2. แก้ไข Bug ลำดับเมนู เนื่องจากมี <div class="nav-sep"></div> แทรกอยู่
  var navIdx={dashboard:0,certificates:1,add:2,ranking:3,settings:4,export:5,ebooks:6,resume:7};
  var items=document.querySelectorAll('.nav-item');
  if(navIdx[page]!==undefined && items[navIdx[page]]){
      items[navIdx[page]].classList.add('active');
  }
  
  if(page==='dashboard')renderDashboard();
  if(page==='certificates'){populateFilters();renderCerts();}
  if(page==='add')populateForm();
  if(page==='ranking')renderRanking();
  if(page==='settings')renderSettings();
  if(page==='export')updateStorageBar();
  if(page==='ebooks'){populateEbookForm();renderEbooks();}
  if(page==='resume'){loadResumeInfo();updateResumeStats();}
}

function getLevelScore(level){return C.scores[level]||0;}

function populateForm(){
  function fillSel(id,arr,placeholder){
    var s=document.getElementById(id);
    s.innerHTML='<option value="">'+placeholder+'</option>'+arr.map(function(a){return '<option value="'+a+'">'+a+'</option>';}).join('');
  }
  fillSel('f-type',C.types,'-- '+t('form_type').replace(' *','')+' --');
  fillSel('f-level',C.levels,'-- '+t('form_level').replace(' *','')+' --');
  fillSel('f-award',C.awards,'-- '+t('form_award')+' --');
  updateScorePreview();
}

function updateScorePreview(){
  var lv=document.getElementById('f-level').value;
  var sc=lv?getLevelScore(lv):'-';
  document.getElementById('f-score-preview').textContent=lv?(sc+' '+t('score_unit')):'-';
}

function populateFilters(){
  function fillSel(id,arr,placeholder){
    var s=document.getElementById(id);var cur=s.value;
    s.innerHTML='<option value="">'+placeholder+'</option>'+arr.map(function(a){return '<option value="'+a+'"'+(a===cur?' selected':'')+'>'+a+'</option>';}).join('');
  }
  fillSel('s-type',C.types,t('filter_all_type'));
  fillSel('s-level',C.levels,t('filter_all_level'));
  fillSel('s-award',C.awards,t('filter_all_award'));
  var years=[...new Set(db.map(function(c){return c.date?c.date.slice(0,4):'';}).filter(Boolean))].sort().reverse();
  var sy=document.getElementById('s-year');var cury=sy.value;
  sy.innerHTML='<option value="">'+t('filter_all_year')+'</option>'+years.map(function(y){return '<option value="'+y+'"'+(y===cury?' selected':'')+'>'+y+'</option>';}).join('');
}

function formatDate(d){if(!d)return'-';var p=d.split('-');if(p.length!==3) return d; return p[2]+'/'+p[1]+'/'+(parseInt(p[0])+543);}

function getLevelBadge(level){
  var colors={นานาชาติ:'#F4C0D1:#72243E',ชาติ:'#FFF8E1:#7B5E00',ภาค:'#B5D4F4:#0C447C',จังหวัด:'#C0DD97:#27500A',เทศบาล:'#D3D1C7:#444441',สถานศึกษา:'#F1EFE8:#5F5E5A'};
  var c=colors[level]||'#eee:#333';var p=c.split(':');
  return 'background:'+p[0]+';color:'+p[1];
}

function getSorted(){
  var q=(document.getElementById('s-search').value||'').toLowerCase();
  var ft=document.getElementById('s-type').value;
  var fl=document.getElementById('s-level').value;
  var fa=document.getElementById('s-award').value;
  var fy=document.getElementById('s-year').value;
  var fp=document.getElementById('s-privacy') ? document.getElementById('s-privacy').value : '';
  var arr=db.filter(function(c){
    return (!q||c.name.toLowerCase().includes(q))&&(!ft||c.type===ft)&&(!fl||c.level===fl)&&(!fa||c.award===fa)&&(!fy||c.date.startsWith(fy))&&(!fp||(c.privacy||'public')===fp);
  });
  arr.sort(function(a,b){
    if(sortMode==='new')return new Date(b.date)-new Date(a.date);
    if(sortMode==='old')return new Date(a.date)-new Date(b.date);
    return (b.score||0)-(a.score||0);
  });
  return arr;
}

function setSort(m){
  sortMode=m;
  ['new','old','score'].forEach(function(x){document.getElementById('srt-'+x).classList.toggle('active',x===m);});
  renderCerts();
}

function renderCerts(){
  var arr=getSorted();
  var grid=document.getElementById('certs-grid');
  var empty=document.getElementById('certs-empty');
  if(!arr.length){grid.innerHTML='';empty.style.display='block';return;}
  empty.style.display='none';
  grid.innerHTML=arr.map(function(c){
    var thumb=c.image?'<img src="'+c.image+'" style="width:100%;height:100%;object-fit:cover">':'<i class="ti ti-certificate" style="font-size:36px;color:rgba(255,255,255,0.25)"></i>';
    var awardBadge=c.award?'<span class="cert-award-badge">'+c.award+'</span>':'';
    var prv = c.privacy || 'public';
    var prvBadge = getPrivacyBadgeHtml(prv);
    var shareBtn = prv !== 'private'
      ? '<button onclick="event.stopPropagation();openShareModal('+c.id+')" style="background:none;border:none;cursor:pointer;padding:3px 6px;border-radius:6px;color:var(--color-text-tertiary);font-size:12px;display:inline-flex;align-items:center;gap:2px" title="แชร์ลิงก์"><i class="ti ti-share"></i></button>'
      : '<span style="padding:3px 6px;font-size:12px;color:var(--color-text-tertiary)"><i class="ti ti-eye-off"></i></span>';
    return '<div class="cert-card" onclick="openCert('+c.id+')">'
      +'<div class="cert-thumb">'+thumb
      +'<span class="cert-badge" style="'+getLevelBadge(c.level)+'">'+c.level+'</span>'
      +awardBadge+'</div>'
      +'<div class="cert-body"><div class="cert-name">'+c.name+'</div>'
      +'<div class="cert-meta"><span>'+c.type+'</span><span>'+formatDate(c.date)+'</span>'+(c.org?'<span>'+c.org+'</span>':'')+'</div>'
      +renderLinkPills(c)
      +'<div style="display:flex;align-items:center;justify-content:space-between;margin-top:5px">'
      +'<div class="cert-score"><i class="ti ti-star" style="font-size:11px"></i>'+(c.score||0)+' คะแนน</div>'
      +prvBadge+shareBtn
      +'</div>'
      +'</div></div>';
  }).join('');
}

function renderLinkPills(c){
  var html='';
  if(c.videoUrl){html+='<a class="link-pill link-pill-youtube" href="'+c.videoUrl+'" target="_blank" rel="noopener"><i class="ti ti-brand-youtube"></i> วิดีโอ</a>';}
  if(c.githubUrl){html+='<a class="link-pill link-pill-github" href="'+c.githubUrl+'" target="_blank" rel="noopener"><i class="ti ti-brand-github"></i> GitHub</a>';}
  if(c.demoUrl){html+='<a class="link-pill link-pill-demo" href="'+c.demoUrl+'" target="_blank" rel="noopener"><i class="ti ti-external-link"></i> Demo</a>';}
  return html?'<div class="link-btn-row">'+html+'</div>':'';
}

function openCert(id){
  var c=db.find(function(x){return x.id===id;});if(!c)return;
  var mc=document.getElementById('modal-content');
  mc.innerHTML=(c.image
    ? '<div style="position:relative;margin-bottom:0">'
      + '<img class="cert-detail-img" src="'+c.image+'" style="cursor:zoom-in" onclick="openLightbox(\''+c.image.replace(/'/g,"\\'")+'\',' + '\''+c.name.replace(/'/g,"\\'")+'\')">  '
      + '<button class="img-fullview-btn" style="bottom:18px;right:8px" onclick="openLightbox(\''+c.image.replace(/'/g,"\\'")+'\',' + '\''+c.name.replace(/'/g,"\\'")+'\')"><i class="ti ti-arrows-maximize"></i> ดูภาพเต็ม</button>'
      + '</div>'
    : '')
    +'<div style="font-size:16px;font-weight:700;margin-bottom:6px;color:var(--color-text-primary)">'+c.name+'</div>'
    +'<span class="cert-badge" style="position:static;display:inline-block;margin-bottom:4px;'+getLevelBadge(c.level)+'">'+c.level+'</span> '
    +(c.award?'<span class="cert-award-badge" style="position:static;display:inline-block;margin-bottom:4px">'+c.award+'</span> ':'')
    +'<span class="cert-score" style="display:inline-flex;margin-bottom:4px"><i class="ti ti-star" style="font-size:11px"></i>'+(c.score||0)+' คะแนน</span> '
    +getPrivacyBadgeHtml(c.privacy||'public')
    +'<div class="detail-grid">'
    +'<div class="detail-row"><div class="detail-key">ประเภท</div><div class="detail-val">'+c.type+'</div></div>'
    +'<div class="detail-row"><div class="detail-key">วันที่ได้รับ</div><div class="detail-val">'+formatDate(c.date)+'</div></div>'
    +(c.org?'<div class="detail-row"><div class="detail-key">หน่วยงาน</div><div class="detail-val">'+c.org+'</div></div>':'')
    +(c.note?'<div class="detail-row"><div class="detail-key">หมายเหตุ</div><div class="detail-val">'+c.note+'</div></div>':'')
