// Minimal QR-like visual (pattern placeholder — real QR via data URL encoding)
function drawSimpleQR(text, canvas, size) {
  var ctx = canvas.getContext('2d');
  canvas.width = size; canvas.height = size;
  ctx.fillStyle = '#fff';
  ctx.fillRect(0, 0, size, size);
  // Encode to simple visual grid based on char codes
  var cells = 21;
  var cell = Math.floor(size / cells);
  var hash = 0;
  for (var i = 0; i < text.length; i++) hash = ((hash << 5) - hash + text.charCodeAt(i)) | 0;
  // Draw finder patterns
  function drawFinder(ox, oy) {
    ctx.fillStyle = '#1a2744';
    ctx.fillRect(ox*cell, oy*cell, 7*cell, 7*cell);
    ctx.fillStyle = '#fff';
    ctx.fillRect((ox+1)*cell, (oy+1)*cell, 5*cell, 5*cell);
    ctx.fillStyle = '#1a2744';
    ctx.fillRect((ox+2)*cell, (oy+2)*cell, 3*cell, 3*cell);
  }
  drawFinder(0,0); drawFinder(cells-7,0); drawFinder(0,cells-7);
  // Data cells based on hash
  ctx.fillStyle = '#1a2744';
  for (var r = 0; r < cells; r++) {
    for (var c2 = 0; c2 < cells; c2++) {
      if ((r < 8 && c2 < 8) || (r < 8 && c2 > cells-9) || (r > cells-9 && c2 < 8)) continue;
      var bit = ((hash ^ (r * 97 + c2 * 31)) * (r + c2 + 1)) & 1;
      // mix with text bytes
      var tIdx = (r * cells + c2) % text.length;
      bit ^= (text.charCodeAt(tIdx) >> (c2 % 8)) & 1;
      if (bit) ctx.fillRect(c2*cell, r*cell, cell, cell);
    }
  }
  ctx.strokeStyle = '#1a2744'; ctx.lineWidth = 2;
  ctx.strokeRect(1, 1, size-2, size-2);
}

