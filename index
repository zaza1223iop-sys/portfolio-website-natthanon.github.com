function handleEbookImgBBDrop(e) {
  e.preventDefault();
  document.getElementById('eb-imgbb-drop-zone').style.borderColor = '';
  var file = e.dataTransfer.files[0];
  if (file && file.type.startsWith('image/')) uploadEbookCoverToImgBB(file);
}

function uploadEbookCoverToImgBB(file) {
  if (!file) return;
  var key = getImgBBKey();
  if (!key) {
    showToast('กรุณาตั้งค่า ImgBB API Key ก่อน (ตั้งค่าระบบ/หน้าบ้าน)');
    document.getElementById('eb-imgbb-no-key-warn').style.display = 'block';
    return;
  }
  compressImage(file, function(dataUrl) {
    var byteStr = atob(dataUrl.split(',')[1]);
    var arr = new Uint8Array(byteStr.length);
    for (var i = 0; i < byteStr.length; i++) arr[i] = byteStr.charCodeAt(i);
    var blob = new Blob([arr], {type: 'image/jpeg'});
    var formData = new FormData();
    formData.append('image', blob, 'ebook-cover.jpg');
    formData.append('key', key);

    var wrap = document.getElementById('eb-imgbb-progress-wrap');
    var bar  = document.getElementById('eb-imgbb-progress-bar');
    var lbl  = document.getElementById('eb-imgbb-progress-label');
    wrap.style.display = 'block';
    bar.style.width = '0%';
    bar.style.background = '#185FA5';
    lbl.textContent = 'กำลังอัปโหลดไป ImgBB...';

    var pct = 0;
    var timer = setInterval(function() {
      pct = Math.min(pct + 10, 85);
      bar.style.width = pct + '%';
    }, 200);

    fetch('https://api.imgbb.com/1/upload', { method: 'POST', body: formData })
      .then(function(r) { return r.json(); })
      .then(function(data) {
        clearInterval(timer);
        if (data.success) {
          bar.style.width = '100%';
          bar.style.background = '#3B6D11';
          lbl.textContent = '✅ อัปโหลดสำเร็จ! รูปปกพร้อมใช้งาน';
          var imgUrl = data.data.display_url || data.data.url;
          var prev = document.getElementById('eb-cover-preview');
          prev.src = imgUrl; prev.style.display = 'block'; prev.dataset.coverData = imgUrl;
          document.getElementById('eb-cover-clear-btn').style.display = 'inline-flex';
          document.getElementById('eb-imgbb-upload-text').textContent = 'อัปโหลดสำเร็จ! คลิกเพื่อเปลี่ยนรูปปก';
        } else {
          bar.style.background = '#c0392b'; bar.style.width = '100%';
          var msg = (data.error && data.error.message) ? data.error.message : 'ไม่ทราบสาเหตุ';
          lbl.textContent = '❌ อัปโหลดไม่สำเร็จ: ' + msg;
        }
      })
      .catch(function(err) {
        clearInterval(timer);
        bar.style.background = '#c0392b'; bar.style.width = '100%';
        lbl.textContent = '❌ เชื่อมต่อไม่ได้: ' + err.message;
      });
  });
}

