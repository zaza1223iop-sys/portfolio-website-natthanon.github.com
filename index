function applyPortfolioTheme(name) {
  _currentTheme = name;
  // Remove all theme classes
  Object.values(THEMES).forEach(function(t){ if (t.body) document.body.classList.remove(t.body); });
  // Apply new theme
  if (THEMES[name] && THEMES[name].body) document.body.classList.add(THEMES[name].body);
  // Update picker UI
  document.querySelectorAll('.theme-card').forEach(function(el){ el.classList.remove('selected'); });
  var sel = document.getElementById('theme-card-'+name);
  if (sel) sel.classList.add('selected');
  // Save
  try { localStorage.setItem('nn_portfolio_theme', name); } catch(e){}
  // Toast
  var msg = document.getElementById('theme-applied-msg');
  var toast = document.getElementById('theme-applied-toast');
  if (msg) msg.textContent = '✅ ใช้ธีม ' + (THEMES[name]||{}).label + ' แล้ว';
  if (toast) { toast.style.display = 'flex'; setTimeout(function(){ toast.style.display='none'; }, 2500); }
  // Re-apply public view theme color
  var cfg = loadSiteSettings();
  applyTheme(cfg.color || '#1a2744');
