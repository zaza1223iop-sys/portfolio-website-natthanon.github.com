  border-color:#B8860B;
  box-shadow:0 4px 16px rgba(184,134,11,0.15);
  transform:translateY(-1px);
}
.ocr-match-thumb{
  width:48px;height:48px;background:#1a2744;border-radius:8px;
  flex-shrink:0;overflow:hidden;display:flex;align-items:center;justify-content:center;
}
.ocr-match-thumb img{width:100%;height:100%;object-fit:cover;}
.ocr-match-info{flex:1;min-width:0;}
.ocr-match-name{font-size:13px;font-weight:700;color:var(--color-text-primary);line-height:1.3;margin-bottom:3px;}
.ocr-match-meta{font-size:11px;color:var(--color-text-secondary);}
.ocr-match-score{
  font-size:16px;font-weight:800;color:#B8860B;
  display:flex;align-items:center;gap:3px;white-space:nowrap;
