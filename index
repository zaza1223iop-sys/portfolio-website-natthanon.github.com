  var systemPrompt = isThai
    ? 'คุณเป็นผู้เชี่ยวชาญด้านการเขียนคำอธิบายผลงานและรางวัลทางวิชาการและวิชาชีพ ตอบกลับเป็น JSON เท่านั้น ไม่มีข้อความอื่น ไม่มี markdown ไม่มี backtick'
    : 'You are an expert at writing professional achievement descriptions and award statements. Reply ONLY with JSON, no markdown, no backticks, no extra text.';

  var userPrompt = isThai
    ? ('สร้างคำอธิบายผลงานจากข้อมูลต่อไปนี้:\n'
      + 'ชื่อผลงาน: ' + name + '\n'
      + (type  ? 'ประเภท: ' + type + '\n' : '')
      + (level ? 'ระดับ: ' + level + '\n' : '')
      + (award ? 'รางวัล: ' + award + '\n' : '')
      + (org   ? 'หน่วยงาน: ' + org + '\n' : '')
      + (note  ? 'หมายเหตุ: ' + note + '\n' : '')
      + (extra ? 'ข้อมูลเพิ่มเติม: ' + extra + '\n' : '')
      + '\nตอบกลับเป็น JSON รูปแบบ:\n{"description":"คำอธิบายผลงาน 2-4 ประโยค ภาษาไทย เป็นทางการ","highlights":["จุดเด่น 1","จุดเด่น 2","จุดเด่น 3","จุดเด่น 4"],"awardStatement":"ประโยคกระชับสำหรับยื่นรางวัล 1-2 ประโยค ภาษาไทย"}'
      )
    : ('Generate an achievement description from the following:\n'
