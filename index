/* ===== OCR SCAN STYLES ===== */
#ocr-modal {
  position:fixed;inset:0;background:rgba(0,0,0,0.65);z-index:1100;
  display:none;align-items:center;justify-content:center;padding:16px;
  backdrop-filter:blur(4px);
}
#ocr-modal.show{display:flex;}
.ocr-box{
  background:var(--color-background-primary);border-radius:20px;
  width:100%;max-width:540px;max-height:94vh;overflow-y:auto;
  box-shadow:0 28px 90px rgba(0,0,0,0.45);
  animation:popupSlideUp 0.32s cubic-bezier(0.34,1.56,0.64,1);
}
.ocr-header{
  background:linear-gradient(135deg,#0f1f4a 0%,#1a2744 100%);
  padding:16px 20px;border-radius:20px 20px 0 0;
  display:flex;align-items:center;gap:12px;position:sticky;top:0;z-index:2;
}
.ocr-header-icon{
  width:42px;height:42px;border-radius:12px;
  background:linear-gradient(135deg,#E8B84B,#B8860B);
  display:flex;align-items:center;justify-content:center;
  font-size:20px;flex-shrink:0;
  box-shadow:0 3px 10px rgba(232,184,75,0.5);
}
.ocr-header-title{font-size:15px;font-weight:700;color:#fff;}
.ocr-header-sub{font-size:11px;color:rgba(255,255,255,0.5);margin-top:2px;}
.ocr-close{
  width:30px;height:30px;border-radius:50%;
  background:rgba(255,255,255,0.12);border:none;color:rgba(255,255,255,0.7);
  font-size:14px;cursor:pointer;display:flex;align-items:center;justify-content:center;
  transition:background 0.12s;margin-left:auto;flex-shrink:0;
}
.ocr-close:hover{background:rgba(255,255,255,0.25);color:#fff;}
.ocr-body{padding:18px 20px 22px;}
.ocr-drop-zone{
  border:2.5px dashed #B8860B;border-radius:14px;
  padding:32px 20px;text-align:center;cursor:pointer;
  background:linear-gradient(135deg,#FFF8E1,#FFFDE7);
  transition:all 0.18s;position:relative;overflow:hidden;
}
.ocr-drop-zone:hover,.ocr-drop-zone.drag-over{
  background:linear-gradient(135deg,#FFF3CD,#FFF8E1);
  border-color:#E8B84B;box-shadow:0 0 0 4px rgba(232,184,75,0.15);
}
.ocr-drop-icon{font-size:40px;margin-bottom:8px;display:block;}
.ocr-drop-title{font-size:14px;font-weight:700;color:#7B5E00;margin-bottom:4px;}
.ocr-drop-sub{font-size:12px;color:#9B7E00;}
.ocr-preview-wrap{
  position:relative;margin-top:12px;display:none;
}
.ocr-preview-img{
  width:100%;max-height:260px;object-fit:contain;
  border-radius:10px;border:1.5px solid rgba(184,134,11,0.3);
