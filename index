/* Responsive ปรับให้เหมาะกับจอมือถือ/แท็บเล็ต */
@media (max-width: 768px) {
  .app { flex-direction: column; }
  .sidebar { width: 100%; height: auto; position: static; min-width: 0; }
  .nav { display: flex; flex-wrap: wrap; padding: 0 10px; border-bottom: 1px solid var(--color-border-tertiary); }
  .nav-item { border-left: none; border-bottom: 3px solid transparent; padding: 10px; }
  .nav-item.active { border-left-color: transparent; border-bottom-color: #E8B84B; }
  .nav-sep { display: none; }
  .chart-row, .form-grid { grid-template-columns: 1fr; }
  .stats-grid { grid-template-columns: 1fr 1fr; }
}

/* ===== PUBLIC SYSTEM STYLES ===== */
#public-view {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 500;
  overflow-y: auto;
  background: var(--color-background-tertiary);
  font-family: var(--font-sans);
}
#public-view.active {
  display: block;
}

/* Public Header */
.pub-header {
  background: #1a2744;
  padding: 0 24px;
  display: flex;
  align-items: center;
  gap: 14px;
  position: sticky;
  top: 0;
  z-index: 50;
  box-shadow: 0 2px 12px rgba(0,0,0,0.18);
  min-height: 58px;
}
.pub-logo-box {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  background: #E8B84B;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 17px;
  font-weight: 700;
  color: #1a2744;
  flex-shrink: 0;
  overflow: hidden;
}
.pub-logo-box img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
.pub-org-name { font-size: 15px; font-weight: 600; color: #fff; flex: 1; }
.pub-header-actions { display: flex; align-items: center; gap: 8px; }
.pub-view-toggle { display: flex; background: rgba(255,255,255,0.1); border-radius: 8px; overflow: hidden; }
.pub-view-btn {
  padding: 6px 10px;
  font-size: 13px;
  cursor: pointer;
  color: rgba(255,255,255,0.6);
  border: none;
  background: none;
  display: flex;
  align-items: center;
  gap: 4px;
  transition: all 0.12s;
}
.pub-view-btn.active { background: #E8B84B; color: #1a2744; }
.pub-admin-btn {
  padding: 7px 14px;
  background: rgba(255,255,255,0.12);
  border: 1px solid rgba(255,255,255,0.2);
  border-radius: 8px;
  color: #fff;
  font-size: 12px;
  cursor: pointer;
  display: flex;
  align-items: center;
  gap: 5px;
  transition: background 0.12s;
}
.pub-admin-btn:hover { background: rgba(255,255,255,0.2); }

/* Public Hero */
.pub-hero {
  background: linear-gradient(135deg, #1a2744 0%, #2d3f6b 100%);
  padding: 36px 24px;
  text-align: center;
  color: #fff;
}
.pub-hero-logo {
  width: 72px;
  height: 72px;
  border-radius: 50%;
  background: #E8B84B;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 30px;
  font-weight: 700;
  color: #1a2744;
  margin: 0 auto 12px;
  overflow: hidden;
}
.pub-hero-logo img { width: 100%; height: 100%; object-fit: cover; border-radius: 50%; }
.pub-hero h1 { font-size: 22px; font-weight: 700; margin-bottom: 4px; }
.pub-hero p { font-size: 13px; color: rgba(255,255,255,0.65); }
.pub-stats-row {
  display: flex;
  justify-content: center;
  gap: 24px;
  margin-top: 20px;
  flex-wrap: wrap;
}
.pub-stat-pill {
  background: rgba(255,255,255,0.1);
  border-radius: 20px;
  padding: 8px 18px;
  text-align: center;
}
.pub-stat-pill .num { font-size: 20px; font-weight: 700; color: #E8B84B; }
.pub-stat-pill .lbl { font-size: 11px; color: rgba(255,255,255,0.65); margin-top: 2px; }

/* Public Search/Filter Bar */
.pub-filter-bar {
  background: var(--color-background-primary);
  border-bottom: 0.5px solid var(--color-border-tertiary);
  padding: 12px 24px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
  align-items: center;
  position: sticky;
  top: 58px;
  z-index: 40;
}
.pub-search {
  flex: 1;
  min-width: 180px;
  font-size: 13px;
  padding: 8px 12px 8px 34px;
  border: 0.5px solid var(--color-border-tertiary);
  border-radius: 8px;
  background: var(--color-background-secondary);
  color: var(--color-text-primary);
  position: relative;
}
.pub-search-wrap { position: relative; flex: 1; min-width: 180px; }
.pub-search-wrap i { position: absolute; left: 10px; top: 50%; transform: translateY(-50%); font-size: 15px; color: var(--color-text-tertiary); pointer-events: none; }
.pub-search-wrap input { width: 100%; font-size: 13px; padding: 8px 12px 8px 32px; border: 0.5px solid var(--color-border-tertiary); border-radius: 8px; background: var(--color-background-secondary); color: var(--color-text-primary); }
.pub-filter-sel {
  font-size: 12px;
  padding: 7px 10px;
  border: 0.5px solid var(--color-border-tertiary);
  border-radius: 8px;
  background: var(--color-background-secondary);
  color: var(--color-text-secondary);
}

/* Public Grid / List */
.pub-content { padding: 20px 24px; max-width: 1100px; margin: 0 auto; }
.pub-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 14px; }
.pub-list { display: flex; flex-direction: column; gap: 10px; }

/* Card view */
.pub-card {
  background: var(--color-background-primary);
  border: 0.5px solid var(--color-border-tertiary);
  border-radius: 14px;
  overflow: hidden;
  cursor: pointer;
  transition: transform 0.14s, box-shadow 0.14s;
}
.pub-card:hover { transform: translateY(-3px); box-shadow: 0 6px 20px rgba(26,39,68,0.12); }
.pub-card-thumb {
  width: 100%;
  height: 130px;
  background: #1a2744;
  display: flex;
  align-items: center;
  justify-content: center;
  position: relative;
  overflow: hidden;
}
.pub-card-thumb img { width: 100%; height: 100%; object-fit: cover; }
.pub-card-thumb-icon { font-size: 38px; color: rgba(255,255,255,0.2); }
.pub-card-body { padding: 11px 13px; }
.pub-card-name { font-size: 13px; font-weight: 600; line-height: 1.3; margin-bottom: 5px; color: var(--color-text-primary); }
.pub-card-date { font-size: 11px; color: var(--color-text-tertiary); }
.pub-card-desc { font-size: 12px; color: var(--color-text-secondary); margin-top: 4px; line-height: 1.4; }

/* List view */
.pub-list-item {
  background: var(--color-background-primary);
  border: 0.5px solid var(--color-border-tertiary);
  border-radius: 12px;
  padding: 12px 16px;
  display: flex;
  align-items: center;
  gap: 14px;
  cursor: pointer;
  transition: box-shadow 0.12s;
}
.pub-list-item:hover { box-shadow: 0 4px 14px rgba(26,39,68,0.09); }
.pub-list-thumb {
  width: 50px;
  height: 50px;
  border-radius: 10px;
  background: #1a2744;
  flex-shrink: 0;
  overflow: hidden;
  display: flex;
  align-items: center;
  justify-content: center;
}
.pub-list-thumb img { width: 100%; height: 100%; object-fit: cover; }
.pub-list-info { flex: 1; min-width: 0; }
.pub-list-name { font-size: 14px; font-weight: 600; color: var(--color-text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
.pub-list-meta { font-size: 12px; color: var(--color-text-secondary); margin-top: 3px; display: flex; gap: 10px; flex-wrap: wrap; }
.pub-list-score { font-size: 14px; font-weight: 700; color: #7B5E00; white-space: nowrap; display: flex; align-items: center; gap: 3px; }

/* Badge */
.lv-badge { font-size: 10px; font-weight: 600; padding: 2px 8px; border-radius: 20px; display: inline-block; }

/* ===== PIN LOGIN OVERLAY ===== */
#pin-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(10,14,30,0.75);
  z-index: 700;
  align-items: center;
  justify-content: center;
}
#pin-overlay.show { display: flex; }
.pin-box {
  background: #fff;
  border-radius: 18px;
  padding: 30px 28px;
  width: 320px;
  text-align: center;
  box-shadow: 0 20px 60px rgba(0,0,0,0.3);
}
.pin-box h2 { font-size: 17px; font-weight: 700; color: #1a2744; margin-bottom: 6px; }
.pin-box p { font-size: 13px; color: var(--color-text-secondary); margin-bottom: 20px; }
.pin-dots { display: flex; justify-content: center; gap: 10px; margin-bottom: 20px; }
.pin-dot { width: 14px; height: 14px; border-radius: 50%; border: 2px solid #1a2744; background: transparent; transition: background 0.1s; }
.pin-dot.filled { background: #1a2744; }
.pin-keypad { display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; }
.pin-key {
  height: 50px;
  border-radius: 10px;
  border: 0.5px solid var(--color-border-tertiary);
  background: var(--color-background-secondary);
  font-size: 18px;
  font-weight: 600;
  color: #1a2744;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.1s, transform 0.08s;
}
.pin-key:active { transform: scale(0.93); background: #e2e8f0; }
.pin-key.del { font-size: 15px; color: #c0392b; }
.pin-key.enter { background: #1a2744; color: #E8B84B; }
.pin-err { font-size: 12px; color: #c0392b; margin-top: 10px; min-height: 18px; }
.pin-close { position: absolute; top: 12px; right: 14px; cursor: pointer; font-size: 18px; color: var(--color-text-secondary); }

/* ===== ADMIN PANEL ===== */
#admin-panel {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(10,14,30,0.6);
  z-index: 600;
  align-items: flex-end;
  justify-content: center;
}
#admin-panel.show { display: flex; }
.admin-sheet {
  background: #fff;
  border-radius: 20px 20px 0 0;
  width: 100%;
  max-width: 600px;
  max-height: 88vh;
  overflow-y: auto;
  padding: 24px 24px 36px;
}
.admin-sheet-handle { width: 40px; height: 4px; background: #e2e8f0; border-radius: 4px; margin: 0 auto 18px; }
.admin-sheet h2 { font-size: 16px; font-weight: 700; margin-bottom: 16px; color: #1a2744; display: flex; align-items: center; gap: 7px; }
.admin-section { margin-bottom: 20px; }
.admin-label { font-size: 12px; font-weight: 600; color: var(--color-text-secondary); margin-bottom: 6px; }
.admin-input {
  width: 100%;
  font-size: 13px;
  padding: 9px 12px;
  border: 0.5px solid var(--color-border-tertiary);
  border-radius: 8px;
  background: var(--color-background-secondary);
  color: var(--color-text-primary);
}
.admin-input:focus { outline: none; border-color: #B8860B; box-shadow: 0 0 0 3px rgba(184,134,11,0.1); }
.color-row { display: flex; gap: 8px; flex-wrap: wrap; margin-top: 6px; }
.color-swatch {
  width: 30px;
  height: 30px;
  border-radius: 50%;
  cursor: pointer;
  border: 3px solid transparent;
  transition: border-color 0.1s, transform 0.1s;
}
.color-swatch:hover { transform: scale(1.1); }
.color-swatch.selected { border-color: #1a2744; }
.admin-actions { display: flex; gap: 8px; margin-top: 8px; flex-wrap: wrap; }

/* Embed Modal */
.embed-box {
  background: #1a2744;
  color: #E8B84B;
  border-radius: 10px;
  padding: 14px;
  font-size: 12px;
  font-family: monospace;
  white-space: pre-wrap;
  word-break: break-all;
  margin-top: 10px;
  max-height: 160px;
  overflow-y: auto;
}

/* Public Responsive */
@media (max-width: 600px) {
  .pub-content { padding: 14px 12px; }
  .pub-filter-bar { padding: 10px 12px; }
  .pub-hero { padding: 24px 16px; }
  .pub-grid { grid-template-columns: repeat(auto-fill, minmax(160px, 1fr)); gap: 10px; }
  .pub-stats-row { gap: 12px; }
  .pin-box { width: 92vw; }
}

/* ===== PUBLIC DETAIL OVERLAY ===== */
#pub-detail-overlay {
  display: none;
  position: fixed;
  inset: 0;
  z-index: 600;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(6px);
  -webkit-backdrop-filter: blur(6px);
  align-items: center;
  justify-content: center;
  padding: 16px;
  animation: pubOverlayIn 0.2s ease;
}
#pub-detail-overlay.show { display: flex; }

@keyframes pubOverlayIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.pub-detail-sheet {
  background: var(--color-background-primary);
  border-radius: 20px;
  width: 100%;
  max-width: 560px;
  max-height: 92vh;
  overflow-y: auto;
  position: relative;
  animation: pubSheetIn 0.25s cubic-bezier(0.34,1.56,0.64,1);
  box-shadow: 0 24px 80px rgba(0,0,0,0.3);
}

@keyframes pubSheetIn {
  from { transform: scale(0.92) translateY(24px); opacity: 0; }
  to { transform: scale(1) translateY(0); opacity: 1; }
}

.pub-detail-hero {
  width: 100%;
  height: 220px;
  object-fit: cover;
  border-radius: 20px 20px 0 0;
