.link-input-group{display:flex;gap:6px;align-items:center;margin-top:5px}
.link-input-group input{flex:1;font-size:12px;padding:7px 10px;border:0.5px solid var(--color-border-tertiary);border-radius:8px;background:var(--color-background-primary);color:var(--color-text-primary)}
.link-input-group input:focus{outline:none;border-color:#B8860B;box-shadow:0 0 0 3px rgba(184,134,11,0.1)}
