function renderResumeResult(data, isThai, style) {
  // Plain text version
  var lines = [];
  var h = data.header || {};
  lines.push('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  lines.push(h.name || '');
  if (h.position) lines.push(h.position);
  if (h.contact) lines.push(h.contact);
  lines.push('━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━');
  if (data.objective) {
    lines.push('');
    lines.push(isThai ? '▌ วัตถุประสงค์ / Objective' : '▌ Career Objective');
    lines.push(data.objective);
  }
  if (data.education && data.education.length) {
    lines.push('');
    lines.push(isThai ? '▌ การศึกษา' : '▌ Education');
    data.education.forEach(function(e){ lines.push('• '+e.institution+(e.degree?' | '+e.degree:'')+(e.year?' ('+e.year+')':'')); });
  }
  if (data.achievements && data.achievements.length) {
    lines.push('');
    lines.push(isThai ? '▌ ผลงาน / รางวัล / เกียรติบัตร' : '▌ Achievements & Awards');
    data.achievements.forEach(function(a,i){ lines.push((i+1)+'. '+a.title+(a.year?' ('+a.year+')':'')+(a.detail?'\n   '+a.detail:'')); });
  }
  if (data.skills && data.skills.length) {
    lines.push('');
    lines.push(isThai ? '▌ ทักษะ / Skills' : '▌ Skills');
    lines.push(data.skills.join(' • '));
  }
  if (data.summary) {
    lines.push('');
    lines.push(isThai ? '▌ สรุป' : '▌ Summary');
    lines.push(data.summary);
  }

  document.getElementById('rv-result-content').textContent = lines.join('\n');

  // HTML PDF preview
  var info = {};
  try { info = JSON.parse(localStorage.getItem('nn_resume_info')||'{}'); } catch(e){}

  var accentColor = style === 'modern' ? '#185FA5' : style === 'academic' ? '#3B6D11' : '#1a2744';
  var achievementsHtml = (data.achievements||[]).map(function(a,i){
    return '<div style="display:flex;gap:10px;margin-bottom:10px">'
