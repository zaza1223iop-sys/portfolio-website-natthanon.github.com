function uploadToDriveViaScript() {
  var cfg = loadSiteSettings();
  var url = (cfg.appsScriptUploadUrl || '').trim();
  var msg = document.getElementById('drive-upload-msg');
  var btn = document.getElementById('btn-drive-upload-go');
  if (!url) {
    showToast('กรุณาตั้งค่า Apps Script Upload URL ก่อน');
    if (msg) { msg.textContent = '❌ ยังไม่ได้ตั้งค่า Apps Script Upload URL'; msg.style.color = '#c0392b'; }
    return;
  }
  var file = window._driveUploadFile;
  if (!file) {
    showToast('กรุณาเลือกไฟล์รูปก่อน');
    return;
  }
  if (btn) btn.disabled = true;
  if (msg) { msg.textContent = '⏳ กำลังอัปโหลดรูปไป Drive...'; msg.style.color = 'var(--color-text-secondary)'; }
  compressImage(file, function(dataUrl) {
    var base64 = dataUrl.split(',')[1];
    fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ filename: file.name.replace(/\.[^/.]+$/, '') + '.jpg', mimeType: 'image/jpeg', base64: base64 })
    })
    .then(function(res) {
      return res.json ? res.json() : Promise.resolve({});
    })
    .then(function(result) {
      if (result && result.success && result.fileUrl) {
        var prev = document.getElementById('f-preview');
        prev.src = result.fileUrl;
