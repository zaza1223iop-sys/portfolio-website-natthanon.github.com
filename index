function saveEbook() {
  var title = document.getElementById('eb-title').value.trim();
  var pdfUrl = document.getElementById('eb-pdf-url').value.trim();
  if (!title) { showToast('กรุณากรอกชื่อหนังสือ'); return; }
  if (!pdfUrl) { showToast('กรุณากรอก URL ไฟล์ PDF'); return; }
  var coverEl = document.getElementById('eb-cover-preview');
  var cover = coverEl.dataset.coverData || '';
  var editId = document.getElementById('eb-edit-id').value;
  var now = new Date().toISOString();
  if (editId) {
    var idx = ebookDB.findIndex(function(e){ return e.id == editId; });
    if (idx !== -1) {
      var old = ebookDB[idx];
      ebookDB[idx] = {
        id: old.id, title: title,
        author: document.getElementById('eb-author').value.trim(),
        category: document.getElementById('eb-category').value,
        year: document.getElementById('eb-year').value.trim(),
        pages: parseInt(document.getElementById('eb-pages').value) || 0,
        desc: document.getElementById('eb-desc').value.trim(),
        pdfUrl: pdfUrl, cover: cover || old.cover,
        createdAt: old.createdAt, updatedAt: now
      };
      saveEbookDB(); showToast('แก้ไข E-Book เรียบร้อยแล้ว');
    }
  } else {
    ebookDB.unshift({
      id: Date.now(), title: title,
      author: document.getElementById('eb-author').value.trim(),
      category: document.getElementById('eb-category').value,
      year: document.getElementById('eb-year').value.trim(),
      pages: parseInt(document.getElementById('eb-pages').value) || 0,
      desc: document.getElementById('eb-desc').value.trim(),
      pdfUrl: pdfUrl, cover: cover,
      createdAt: now, updatedAt: now
    });
    saveEbookDB(); showToast('เพิ่ม E-Book เรียบร้อยแล้ว');
  }
  resetEbookForm();
  renderEbooks();
}

