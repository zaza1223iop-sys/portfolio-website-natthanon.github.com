// ===== PIN SYSTEM =====
var pinBuffer = '';
function showPinOverlay() {
  pinBuffer = '';
  document.getElementById('pin-err').textContent = '';
  updatePinDots();
  document.getElementById('pin-overlay').classList.add('show');
}
function hidePinOverlay() {
  document.getElementById('pin-overlay').classList.remove('show');
  pinBuffer = '';
  updatePinDots();
}
function updatePinDots() {
  for (var i = 0; i < 4; i++) {
    document.getElementById('pd'+i).classList.toggle('filled', i < pinBuffer.length);
  }
}
function pinKey(k) {
  if (pinBuffer.length >= 4) return;
  pinBuffer += k;
  updatePinDots();
  document.getElementById('pin-err').textContent = '';
  if (pinBuffer.length === 4) setTimeout(pinEnter, 200);
}
function pinDel() {
  pinBuffer = pinBuffer.slice(0, -1);
  updatePinDots();
}
function pinEnter() {
  var cfg = loadSiteSettings();
  var correctPin = cfg.pin || '1234';
  if (pinBuffer === correctPin) {
    hidePinOverlay();
    // ปิดหน้าบ้าน → เปิดหลังบ้าน
    document.getElementById('public-view').classList.remove('active');
    navigate('dashboard');
  } else {
    document.getElementById('pin-err').textContent = 'PIN ไม่ถูกต้อง กรุณาลองใหม่';
    pinBuffer = '';
    updatePinDots();
    var dots = document.getElementById('pin-dots');
    dots.style.animation = 'none';
    dots.offsetHeight;
    dots.style.animation = 'pinShake 0.3s ease';
  }
}

