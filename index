<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ระบบเกียรติบัตร Portfolio</title>
<link href="https://fonts.googleapis.com/css2?family=Prompt:wght@300;400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/@tabler/icons-webfont@latest/dist/tabler-icons.min.css">
<style>
/* 1. เพิ่ม :root เพื่อกำหนดค่าสี CSS Variables ที่ขาดหายไป */
:root {
  --font-sans: 'Prompt', sans-serif;
  --color-background-primary: #ffffff;
  --color-background-secondary: #f8f9fa;
  --color-background-tertiary: #f1f5f9;
  --color-text-primary: #1e293b;
  --color-text-secondary: #475569;
  --color-text-tertiary: #94a3b8;
  --color-border-tertiary: #e2e8f0;
}

*{box-sizing:border-box;margin:0;padding:0}
body{font-family:var(--font-sans);background:var(--color-background-tertiary);color:var(--color-text-primary)}
.app{display:flex;min-height:100vh}
.sidebar{width:210px;min-width:210px;background:#1a2744;display:flex;flex-direction:column;position:sticky;top:0;height:100vh;overflow-y:auto}
.logo-area{padding:20px 18px 16px;border-bottom:1px solid rgba(255,255,255,0.08)}
.logo-avatar{width:48px;height:48px;border-radius:50%;background:#E8B84B;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:700;color:#1a2744;margin-bottom:8px}
.logo-name{font-size:13px;font-weight:600;color:#fff;line-height:1.3}
.logo-sub{font-size:11px;color:rgba(255,255,255,0.45);margin-top:2px}
.nav{padding:10px 0;flex:1}
.nav-item{display:flex;align-items:center;gap:9px;padding:9px 18px;color:rgba(255,255,255,0.55);font-size:13px;cursor:pointer;border-left:3px solid transparent;transition:all 0.12s}
.nav-item:hover{color:#fff;background:rgba(255,255,255,0.05)}
.nav-item.active{color:#E8B84B;background:rgba(232,184,75,0.1);border-left-color:#E8B84B}
.nav-item i{font-size:15px;min-width:17px}
.nav-sep{height:1px;background:rgba(255,255,255,0.06);margin:6px 14px}
.main{flex:1;overflow-x:hidden}
.topbar{background:var(--color-background-primary);border-bottom:0.5px solid var(--color-border-tertiary);padding:13px 24px;display:flex;align-items:center;gap:10px;position:sticky;top:0;z-index:10}
.topbar-title{font-size:15px;font-weight:600;flex:1}
.content{padding:20px 24px}
.page{display:none}.page.active{display:block}

.card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:12px;padding:18px 20px;margin-bottom:16px}
.card-title{font-size:14px;font-weight:600;margin-bottom:14px;display:flex;align-items:center;gap:6px;color:var(--color-text-primary)}
.card-title i{font-size:16px}

.stats-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:12px;margin-bottom:16px}
.stat-card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:12px;padding:14px 16px}
.stat-card.gold{border-color:rgba(184,134,11,0.3);background:#FFF8E1}
.stat-num{font-size:26px;font-weight:700;line-height:1;color:var(--color-text-primary)}
.stat-card.gold .stat-num{color:#7B5E00}
.stat-label{font-size:11px;color:var(--color-text-secondary);margin-top:4px}
.stat-icon{font-size:20px;margin-bottom:8px}

.filter-bar{display:flex;gap:8px;margin-bottom:16px;flex-wrap:wrap;align-items:center}
.filter-bar select,.filter-bar input[type=text]{font-size:13px;padding:7px 10px;border:0.5px solid var(--color-border-tertiary);border-radius:8px;background:var(--color-background-primary);color:var(--color-text-primary)}
.filter-bar input[type=text]{flex:1;min-width:150px}
.sort-btn{display:flex;align-items:center;gap:4px;font-size:12px;padding:7px 10px;border:0.5px solid var(--color-border-tertiary);border-radius:8px;background:var(--color-background-secondary);cursor:pointer;color:var(--color-text-secondary)}
.sort-btn.active{background:#1a2744;color:#fff;border-color:#1a2744}

.certs-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(200px,1fr));gap:12px}
.cert-card{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:12px;overflow:hidden;cursor:pointer;transition:transform 0.12s}
.cert-card:hover{transform:translateY(-2px)}
.cert-thumb{width:100%;height:120px;background:#1a2744;display:flex;align-items:center;justify-content:center;position:relative}
.cert-thumb img{width:100%;height:100%;object-fit:cover}
.cert-badge{position:absolute;top:7px;right:7px;font-size:10px;font-weight:600;padding:2px 7px;border-radius:20px}
.cert-award-badge{position:absolute;top:7px;left:7px;font-size:10px;font-weight:600;padding:2px 7px;border-radius:20px;background:#1a2744;color:#E8B84B}
.cert-body{padding:10px 12px}
.cert-name{font-size:13px;font-weight:600;margin-bottom:3px;line-height:1.3;color:var(--color-text-primary)}
.cert-meta{font-size:11px;color:var(--color-text-secondary);display:flex;flex-direction:column;gap:2px}
.cert-score{display:inline-flex;align-items:center;gap:3px;font-size:11px;font-weight:600;padding:2px 7px;border-radius:20px;background:#FFF8E1;color:#7B5E00;margin-top:5px}

.form-grid{display:grid;grid-template-columns:1fr 1fr;gap:12px}
.form-group{display:flex;flex-direction:column;gap:4px}
.form-group.full{grid-column:1/-1}
.form-label{font-size:12px;font-weight:600;color:var(--color-text-secondary)}
.form-input{font-size:13px;padding:8px 11px;border:0.5px solid var(--color-border-tertiary);border-radius:8px;background:var(--color-background-primary);color:var(--color-text-primary)}
.form-input:focus{outline:none;border-color:#B8860B;box-shadow:0 0 0 3px rgba(184,134,11,0.1)}
.upload-zone{border:2px dashed var(--color-border-tertiary);border-radius:10px;padding:24px;text-align:center;cursor:pointer;background:var(--color-background-secondary);transition:all 0.12s}
.upload-zone:hover{border-color:#B8860B;background:#FFF8E1}
.upload-zone i{font-size:26px;color:var(--color-text-tertiary);margin-bottom:6px;display:block}
.upload-zone p{font-size:13px;color:var(--color-text-secondary)}
.upload-zone small{font-size:11px;color:var(--color-text-tertiary)}
.preview-img{width:100%;max-height:180px;object-fit:cover;border-radius:8px;border:0.5px solid var(--color-border-tertiary);margin-top:8px;display:none;}

.btn{display:inline-flex;align-items:center;gap:5px;border:none;border-radius:8px;padding:9px 18px;font-size:13px;font-weight:600;cursor:pointer;transition:opacity 0.1s}
.btn:hover{opacity:0.85}
.btn-navy{background:#1a2744;color:#fff}
.btn-gold{background:#B8860B;color:#fff}
.btn-red{background:#c0392b;color:#fff}
.btn-ghost{background:var(--color-background-secondary);color:var(--color-text-primary);border:0.5px solid var(--color-border-tertiary)}

.score-preview{font-size:22px;font-weight:700;color:#7B5E00;padding:4px 0}

.empty-state{text-align:center;padding:40px 20px;color:var(--color-text-tertiary)}
.empty-state i{font-size:36px;display:block;margin-bottom:10px}

.tag-list{display:flex;flex-wrap:wrap;gap:6px;margin-bottom:10px}
.tag-item{display:flex;align-items:center;gap:5px;font-size:12px;padding:4px 10px;border-radius:20px;border:0.5px solid var(--color-border-tertiary);background:var(--color-background-secondary);color:var(--color-text-primary)}
.tag-del{cursor:pointer;color:var(--color-text-tertiary);font-size:13px;display:flex;align-items:center}
.tag-del:hover{color:#c0392b}
.tag-add-row{display:flex;gap:6px;align-items:center}
.tag-add-row input{font-size:13px;padding:6px 10px;border:0.5px solid var(--color-border-tertiary);border-radius:8px;background:var(--color-background-primary);color:var(--color-text-primary);flex:1}
.tag-add-row input:focus{outline:none;border-color:#B8860B}

.score-row{display:flex;align-items:center;gap:10px;padding:8px 0;border-bottom:0.5px solid var(--color-border-tertiary)}
.score-row:last-child{border-bottom:none}
.score-row-name{flex:1;font-size:13px;color:var(--color-text-primary)}
.score-row-pts{font-size:13px;font-weight:700;color:#7B5E00;min-width:40px;text-align:right}
.score-edit-input{font-size:13px;padding:4px 8px;border:0.5px solid var(--color-border-tertiary);border-radius:6px;width:70px;text-align:center;background:var(--color-background-primary);color:var(--color-text-primary)}
.score-edit-input:focus{outline:none;border-color:#B8860B}

.modal-bg{position:fixed;inset:0;background:rgba(0,0,0,0.45);z-index:100;display:none;align-items:center;justify-content:center;padding:20px;}
.modal-bg.show{display:flex}
.modal{background:var(--color-background-primary);border-radius:14px;padding:22px;width:100%;max-width:520px;position:relative;max-height:90vh;overflow-y:auto}
.modal-close{position:absolute;top:14px;right:14px;width:26px;height:26px;border-radius:50%;background:var(--color-background-secondary);border:0.5px solid var(--color-border-tertiary);display:flex;align-items:center;justify-content:center;cursor:pointer;font-size:13px;color:var(--color-text-secondary)}

.chart-row{display:grid;grid-template-columns:1fr 1fr;gap:12px;margin-bottom:16px}
.bar-chart{display:flex;flex-direction:column;gap:7px}
.bar-row{display:flex;align-items:center;gap:7px}
.bar-label{font-size:11px;color:var(--color-text-secondary);min-width:80px;text-align:right}
.bar-wrap{flex:1;background:var(--color-background-secondary);border-radius:4px;height:10px;overflow:hidden}
.bar-fill{height:100%;border-radius:4px;background:#B8860B}
.bar-val{font-size:11px;font-weight:600;min-width:20px;color:var(--color-text-primary)}

.rank-list{display:flex;flex-direction:column;gap:8px}
.rank-item{background:var(--color-background-primary);border:0.5px solid var(--color-border-tertiary);border-radius:10px;padding:12px 14px;display:flex;align-items:center;gap:10px}
.rank-num{font-size:16px;font-weight:700;min-width:28px;text-align:center;color:var(--color-text-primary)}
.rank-num.gold{color:#B8860B}
.rank-num.silver{color:#888}
.rank-num.bronze{color:#CD7F32}
.rank-bar-wrap{flex:1}
.rank-name{font-size:13px;font-weight:600;margin-bottom:3px;color:var(--color-text-primary)}
.rank-sub{font-size:11px;color:var(--color-text-tertiary);margin-bottom:4px}
.rank-bar-bg{background:var(--color-background-secondary);border-radius:4px;height:5px;overflow:hidden}
.rank-bar-fill{height:100%;border-radius:4px;background:#B8860B}
.rank-score{font-size:18px;font-weight:700;color:#7B5E00}

.toast{position:fixed;bottom:18px;right:18px;z-index:200;background:#1a2744;color:#fff;padding:10px 16px;border-radius:10px;font-size:13px;display:flex;align-items:center;gap:7px;transform:translateY(60px);opacity:0;transition:all 0.25s;pointer-events:none}
.toast.show{transform:translateY(0);opacity:1}

/* ===== PRIVACY VISIBILITY SYSTEM ===== */
.prv-badge {
  display: inline-flex; align-items: center; gap: 3px;
  font-size: 10px; font-weight: 700; padding: 2px 7px; border-radius: 20px;
  letter-spacing: 0.02em;
}
.prv-public  { background: #D1FAE5; color: #065F46; }
.prv-private { background: #FEE2E2; color: #991B1B; }
.prv-link    { background: #E0F2FE; color: #0C4A6E; }

.prv-selector {
  display: flex; gap: 4px; flex-wrap: wrap;
}
.prv-opt {
  display: flex; align-items: center; gap: 5px;
  padding: 6px 11px; border-radius: 8px; cursor: pointer;
  font-size: 12px; font-weight: 600; border: 1.5px solid transparent;
  transition: all 0.12s; user-select: none;
}
.prv-opt[data-v="public"]  { background: #D1FAE5; color: #065F46; border-color: #A7F3D0; }
.prv-opt[data-v="link"]    { background: #E0F2FE; color: #0C4A6E; border-color: #BAE6FD; }
.prv-opt[data-v="private"] { background: #FEE2E2; color: #991B1B; border-color: #FECACA; }
.prv-opt.selected[data-v="public"]  { border-color: #059669; box-shadow: 0 0 0 2px rgba(5,150,105,0.2); }
.prv-opt.selected[data-v="link"]    { border-color: #0284C7; box-shadow: 0 0 0 2px rgba(2,132,199,0.2); }
.prv-opt.selected[data-v="private"] { border-color: #DC2626; box-shadow: 0 0 0 2px rgba(220,38,38,0.2); }

/* Share link modal */
#share-modal-bg {
  position: fixed; inset: 0; background: rgba(0,0,0,0.5);
  z-index: 800; display: none; align-items: center; justify-content: center; padding: 20px;
}
#share-modal-bg.show { display: flex; }
.share-modal {
  background: var(--color-background-primary);
  border-radius: 16px; padding: 24px; width: 100%; max-width: 480px;
  box-shadow: 0 20px 60px rgba(0,0,0,0.25);
  animation: popupSlideUp 0.3s cubic-bezier(0.34,1.56,0.64,1);
}
.share-url-box {
  display: flex; gap: 6px; align-items: center;
  background: var(--color-background-secondary);
  border: 0.5px solid var(--color-border-tertiary);
  border-radius: 10px; padding: 10px 12px;
  margin-bottom: 12px;
}
.share-url-text {
  flex: 1; font-size: 12px; color: var(--color-text-secondary);
  word-break: break-all; line-height: 1.4;
  font-family: monospace;
}
.share-copy-btn {
  flex-shrink: 0; display: inline-flex; align-items: center; gap: 4px;
  padding: 6px 12px; border-radius: 8px; font-size: 12px; font-weight: 600;
  background: #1a2744; color: #fff; border: none; cursor: pointer;
  transition: opacity 0.12s;
}
.share-copy-btn:hover { opacity: 0.85; }
.share-qr-wrap {
  text-align: center; padding: 16px;
  background: var(--color-background-secondary);
  border-radius: 10px; margin-top: 10px;
}

/* Single cert public view */
#single-cert-view {
  display: none; position: fixed; inset: 0; z-index: 600;
  background: var(--color-background-tertiary);
  overflow-y: auto; font-family: var(--font-sans);
}
#single-cert-view.active { display: block; }
.single-cert-header {
  background: #1a2744; padding: 14px 20px;
  display: flex; align-items: center; gap: 12px;
  position: sticky; top: 0; z-index: 10;
}
.single-cert-header-title { font-size: 14px; font-weight: 600; color: #fff; flex: 1; }
.single-cert-back { color: rgba(255,255,255,0.7); background: none; border: none; cursor: pointer; font-size: 20px; display: flex; align-items: center; }
.single-cert-back:hover { color: #fff; }
.single-cert-body { max-width: 680px; margin: 0 auto; padding: 24px 20px; }
.single-cert-hero {
  width: 100%; max-height: 380px; object-fit: cover;
  border-radius: 14px;
  border: 0.5px solid var(--color-border-tertiary);
  margin-bottom: 20px;
}
.single-cert-placeholder {
  width: 100%; height: 200px; background: #1a2744;
  border-radius: 14px; display: flex; align-items: center; justify-content: center;
  margin-bottom: 20px;
}
.single-cert-placeholder i { font-size: 60px; color: rgba(255,255,255,0.15); }
.single-cert-title { font-size: 22px; font-weight: 700; color: var(--color-text-primary); margin-bottom: 10px; line-height: 1.3; }
/* ===== END PRIVACY SYSTEM ===== */
#popup-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.55);
  z-index: 900;
  align-items: center;
  justify-content: center;
  padding: 20px;
  backdrop-filter: blur(3px);
  animation: popupFadeIn 0.3s ease;
}
#popup-overlay.show { display: flex; }
@keyframes popupFadeIn { from { opacity:0; } to { opacity:1; } }
@keyframes popupSlideUp { from { opacity:0; transform:translateY(30px) scale(0.96); } to { opacity:1; transform:translateY(0) scale(1); } }

.popup-box {
  background: var(--color-background-primary);
  border-radius: 18px;
  width: 100%;
  max-width: 480px;
  overflow: hidden;
  box-shadow: 0 24px 60px rgba(0,0,0,0.3);
  animation: popupSlideUp 0.35s cubic-bezier(0.34,1.56,0.64,1);
  position: relative;
}
.popup-close-btn {
  position: absolute;
  top: 12px; right: 12px;
  width: 30px; height: 30px;
  border-radius: 50%;
  background: rgba(0,0,0,0.35);
  border: none;
  color: #fff;
  font-size: 15px;
  cursor: pointer;
  display: flex; align-items: center; justify-content: center;
  z-index: 2;
  transition: background 0.12s;
}
.popup-close-btn:hover { background: rgba(0,0,0,0.6); }
.popup-img-wrap {
  width: 100%;
  height: 260px;
  overflow: hidden;
  background: #1a2744;
  position: relative;
}
.popup-img-wrap img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}
.popup-img-placeholder {
  position: absolute;
  top: 50%; left: 50%;
  transform: translate(-50%, -50%);
  font-size: 52px;
  color: rgba(255,255,255,0.2);
}
.popup-body {
  padding: 20px 22px 22px;
}
.popup-title {
  font-size: 18px;
  font-weight: 700;
  color: var(--color-text-primary);
  margin-bottom: 8px;
  line-height: 1.3;
}
.popup-message {
  font-size: 13px;
  color: var(--color-text-secondary);
  line-height: 1.6;
  margin-bottom: 14px;
  white-space: pre-line;
}
.popup-link-btn {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 10px 20px;
  border-radius: 10px;
  font-size: 13px;
  font-weight: 600;
  text-decoration: none;
  color: #fff;
  background: #B8860B;
  transition: opacity 0.12s;
  border: none;
  cursor: pointer;
}
.popup-link-btn:hover { opacity: 0.85; }
.popup-footer {
  display: flex; align-items: center; justify-content: space-between;
  gap: 10px; flex-wrap: wrap;
}
.popup-no-show {
  font-size: 12px;
  color: var(--color-text-tertiary);
  cursor: pointer;
  display: flex; align-items: center; gap: 5px;
  background: none; border: none; padding: 0;
  font-family: var(--font-sans);
}
.popup-no-show:hover { color: var(--color-text-secondary); }

/* Admin panel popup section */
.popup-admin-section {
  background: #F0FFF4;
  border: 1px solid #B2DFDB;
  border-radius: 10px;
  padding: 12px 14px;
  margin-bottom: 12px;
}
.popup-admin-section .admin-label { color: #1B5E20; }
.popup-toggle-row {
  display: flex; align-items: center; justify-content: space-between;
  gap: 8px;
}
.popup-toggle-label { font-size: 13px; color: var(--color-text-primary); }
.popup-toggle {
  position: relative; width: 42px; height: 24px; flex-shrink: 0;
}
.popup-toggle input { opacity: 0; width: 0; height: 0; }
.popup-toggle-slider {
  position: absolute; inset: 0;
  background: #ccc; border-radius: 24px; cursor: pointer;
  transition: background 0.2s;
}
.popup-toggle-slider:before {
  content: '';
  position: absolute;
  width: 18px; height: 18px;
  left: 3px; bottom: 3px;
  background: #fff; border-radius: 50%;
  transition: transform 0.2s;
}
.popup-toggle input:checked + .popup-toggle-slider { background: #3B6D11; }
.popup-toggle input:checked + .popup-toggle-slider:before { transform: translateX(18px); }
.popup-img-tabs { display: flex; gap: 4px; margin-bottom: 8px; }
.popup-img-tab {
  font-size: 12px; padding: 5px 10px; border-radius: 7px; cursor: pointer;
  border: 0.5px solid var(--color-border-tertiary);
  background: var(--color-background-secondary); color: var(--color-text-secondary);
  transition: all 0.12s;
}
.popup-img-tab.active { background: #1a2744; color: #fff; border-color: #1a2744; }
.popup-img-panel { display: none; }
.popup-img-panel.active { display: block; }
.popup-preview-thumb {
  width: 100%; height: 100px; object-fit: cover;
  border-radius: 8px; border: 0.5px solid var(--color-border-tertiary);
  margin-top: 6px; display: none;
}
/* ===== END POPUP STYLES ===== */

.detail-grid{display:grid;grid-template-columns:1fr 1fr;gap:8px;margin-top:10px}
.detail-row{background:var(--color-background-secondary);border-radius:8px;padding:9px 11px}
.detail-key{font-size:11px;color:var(--color-text-tertiary);margin-bottom:2px}
.detail-val{font-size:13px;font-weight:600;color:var(--color-text-primary)}
.cert-detail-img{width:100%;max-height:300px;object-fit:cover;border-radius:10px;margin-bottom:14px;border:0.5px solid var(--color-border-tertiary);display:block}

.pie-wrap{display:flex;gap:14px;align-items:center}
.pie-legend{display:flex;flex-direction:column;gap:6px;justify-content:center}
.legend-row{display:flex;align-items:center;gap:6px;font-size:12px;color:var(--color-text-primary)}
.legend-dot{width:9px;height:9px;border-radius:50%;flex-shrink:0}
.legend-name{flex:1;color:var(--color-text-secondary)}
.legend-num{font-weight:600;color:var(--color-text-primary)}

.section-divider{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.05em;color:var(--color-text-tertiary);padding:4px 0 8px;margin-top:4px}

/* ===== LINK BUTTONS (Video/GitHub/Demo) ===== */
.link-btn-row{display:flex;flex-wrap:wrap;gap:5px;margin-top:7px}
.link-pill{display:inline-flex;align-items:center;gap:4px;font-size:11px;font-weight:600;padding:4px 10px;border-radius:20px;text-decoration:none;transition:opacity 0.12s;cursor:pointer}
.link-pill:hover{opacity:0.8}
.link-pill-youtube{background:#FFE8E8;color:#C00000}
