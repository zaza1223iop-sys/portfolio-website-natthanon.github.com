function saveCert(){
  var name=document.getElementById('f-name').value.trim();
  var date=document.getElementById('f-date').value;
  var type=document.getElementById('f-type').value;
  var level=document.getElementById('f-level').value;
  if(!name||!date||!type||!level){showToast('กรุณากรอกข้อมูลที่มีเครื่องหมาย * ให้ครบถ้วน');return;}
  var prevEl = document.getElementById('f-preview');
  var imgVal = '';
  if (prevEl.dataset.driveUrl) {
    imgVal = prevEl.dataset.driveUrl; // Google Drive URL — ไม่กินพื้นที่
  } else if (prevEl.src && prevEl.src.startsWith('data:')) {
    imgVal = prevEl.src; // base64 จากอัปโหลดไฟล์
  }
  var editId=document.getElementById('f-edit-id').value;

  if(editId){
    // โหมดแก้ไข
    var idx=db.findIndex(function(c){return c.id==editId;});
    if(idx!==-1){
      var old=db[idx];
      db[idx]={
        id:old.id,
        name:name,type:type,level:level,
        award:document.getElementById('f-award').value,
        date:date,org:document.getElementById('f-org').value,
        note:document.getElementById('f-note').value,
        score:getLevelScore(level),
        image:imgVal||old.image,
        privacy:_selectedPrivacy||'public',
        videoUrl:(document.getElementById('f-video-url').value||'').trim(),
        githubUrl:(document.getElementById('f-github-url').value||'').trim(),
        demoUrl:(document.getElementById('f-demo-url').value||'').trim(),
        createdAt:old.createdAt
      };
      saveDB();
      showToast('แก้ไขเกียรติบัตรเรียบร้อยแล้ว');
    }
  } else {
    // โหมดเพิ่มใหม่
    var cert={
      id:Date.now(),name:name,type:type,level:level,
      award:document.getElementById('f-award').value,
      date:date,org:document.getElementById('f-org').value,
      note:document.getElementById('f-note').value,
      score:getLevelScore(level),
      image:imgVal,
      privacy:_selectedPrivacy||'public',
      videoUrl:(document.getElementById('f-video-url').value||'').trim(),
      githubUrl:(document.getElementById('f-github-url').value||'').trim(),
      demoUrl:(document.getElementById('f-demo-url').value||'').trim(),
      createdAt:new Date().toISOString()
    };
    db.unshift(cert);saveDB();
    showToast('บันทึกเกียรติบัตรเรียบร้อยแล้ว');
  }

  // reset form
  document.getElementById('f-edit-id').value='';
  ['f-name','f-date','f-org','f-note','f-video-url','f-github-url','f-demo-url'].forEach(function(id){var el=document.getElementById(id);if(el)el.value='';});
  document.getElementById('f-type').selectedIndex=0;
  document.getElementById('f-level').selectedIndex=0;
  document.getElementById('f-award').selectedIndex=0;
  selectPrivacy('public');
  document.getElementById('f-preview').style.display='none';
  document.getElementById('f-preview').src='';
  document.getElementById('f-preview').dataset.driveUrl='';
  document.getElementById('f-file').value='';
  var driveInp=document.getElementById('f-drive-url');if(driveInp)driveInp.value='';
  var dh=document.getElementById('f-drive-hint');if(dh){dh.textContent='รองรับ: drive.google.com/file/d/… และ drive.google.com/open?id=…';dh.style.color='var(--color-text-tertiary)';}
  document.getElementById('f-score-preview').textContent='-';
  var hint=document.getElementById('f-img-size-hint');if(hint)hint.textContent='';
  var cb=document.getElementById('f-img-clear-btn');if(cb)cb.style.display='none';
  var pw = document.getElementById('imgbb-progress-wrap'); if (pw) pw.style.display = 'none';
  var pb = document.getElementById('imgbb-progress-bar'); if (pb) { pb.style.width = '0%'; pb.style.background = '#185FA5'; }
  var pl = document.getElementById('imgbb-progress-label'); if (pl) pl.textContent = 'กำลังอัปโหลด...';
  var ut = document.getElementById('imgbb-upload-text'); if (ut) ut.textContent = 'คลิกหรือลากรูปมาวางที่นี่';
  switchImgTab('imgbb');
  document.getElementById('form-card-title').innerHTML='<i class="ti ti-circle-plus" style="color:#B8860B"></i> เพิ่มเกียรติบัตรใหม่';
  navigate('certificates');
}

function renderSettings(){
  renderTagList('type');renderTagList('level');renderTagList('award');renderScoreSettings();
}

function renderTagList(key){
  var arr=key==='type'?C.types:key==='level'?C.levels:C.awards;
  var el=document.getElementById('tag-'+key+'-list');
  if(!arr.length){el.innerHTML='<span style="font-size:12px;color:var(--color-text-tertiary)">ยังไม่มีรายการ</span>';return;}
  el.innerHTML=arr.map(function(item,i){
    return '<div class="tag-item">'+item
      +'<span class="tag-del" onclick="deleteTag(\''+key+'\','+i+')" title="ลบ"><i class="ti ti-x" style="font-size:12px"></i></span></div>';
  }).join('');
}

function addTag(key){
  var inp=document.getElementById('inp-'+key);
  var val=inp.value.trim();
  if(!val){return;}
  if(key==='type'){if(C.types.indexOf(val)===-1)C.types.push(val);}
  else if(key==='level'){if(C.levels.indexOf(val)===-1){C.levels.push(val);C.scores[val]=10;}}
  else{if(C.awards.indexOf(val)===-1)C.awards.push(val);}
  inp.value='';saveCfg();renderTagList(key);
  if(key==='level')renderScoreSettings();
  showToast('เพิ่ม "'+val+'" เรียบร้อยแล้ว');
}

function deleteTag(key,idx){
  if(key==='type')C.types.splice(idx,1);
  else if(key==='level'){var lv=C.levels[idx];C.levels.splice(idx,1);delete C.scores[lv];}
  else C.awards.splice(idx,1);
  saveCfg();renderTagList(key);
  if(key==='level')renderScoreSettings();
  showToast('ลบรายการแล้ว');
}

function renderScoreSettings(){
  var el=document.getElementById('score-settings-list');
  el.innerHTML=C.levels.map(function(lv){
    var sc=C.scores[lv]||0;
    return '<div class="score-row">'
      +'<span class="score-row-name">'+lv+'</span>'
      +'<input class="score-edit-input" type="number" min="0" max="9999" value="'+sc+'" id="sc-'+lv+'" oninput="previewScore(\''+lv+'\')">'
      +'<span class="score-row-pts" id="scv-'+lv+'">'+sc+' pt</span>'
      +'</div>';
  }).join('');
}

function previewScore(lv){
  var inp=document.getElementById('sc-'+lv);
  var v=parseInt(inp.value)||0;
