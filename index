function applyTheme(color) {
  document.getElementById('pub-hero').style.background = 'linear-gradient(135deg,' + color + ' 0%, ' + shadeColor(color, 20) + ' 100%)';
  document.getElementById('pub-header-bar') && (document.getElementById('pub-header-bar').style.background = color);
