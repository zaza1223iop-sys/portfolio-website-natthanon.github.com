// ===== Upload รูปไปยัง Google Drive ผ่าน Apps Script =====
// ใช้แทนที่ฟังก์ชัน uploadToDrive เดิมในไฟล์ HTML (ที่มีอยู่แล้ว)
// ฟังก์ชันนี้ override ฟังก์ชัน uploadFileToDrive ที่มีใน HTML
function uploadFileToDriveViaScript(file, callback) {
  var url = getAppsScriptUploadUrl();
  if (!url) {
    showToast('⚠️ ยังไม่ได้ตั้งค่า Apps Script Upload URL — ไปที่ ตั้งค่าระบบ/หน้าบ้าน');
    return;
  }
  var msg  = document.getElementById('drive-upload-msg');
  var btn  = document.getElementById('drive-upload-btn');
  if (btn) btn.disabled = true;
  if (msg) { msg.textContent = '⏳ กำลังอัปโหลดรูปไป Drive...'; msg.style.color = 'var(--color-text-secondary)'; }

  compressImage(file, function(dataUrl) {
    var base64 = dataUrl.split(',')[1];
    fetch(url, {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({
        action: 'uploadImage',
        filename: file.name.replace(/\.[^/.]+$/, '') + '.jpg',
        mimeType: 'image/jpeg',
        base64: base64
      })
    })
    .then(function(res) { return res.json(); })
    .then(function(result) {
      if (result && result.success && result.fileUrl) {
        if (msg) { msg.textContent = '✅ อัปโหลดไป Drive สำเร็จ'; msg.style.color = '#3B6D11'; }
        showToast('อัปโหลดไป Drive สำเร็จ');
        if (callback) callback(result.fileUrl);
      } else {
        var errMsg = (result && result.message) ? result.message : 'ไม่พบการตอบกลับที่ถูกต้อง';
        if (msg) { msg.textContent = '❌ อัปโหลดไม่สำเร็จ: ' + errMsg; msg.style.color = '#c0392b'; }
        showToast('อัปโหลดไป Drive ไม่สำเร็จ');
      }
    })
    .catch(function(err) {
      if (msg) { msg.textContent = '❌ เกิดข้อผิดพลาด: ' + err.message; msg.style.color = '#c0392b'; }
      showToast('อัปโหลดไป Drive ไม่สำเร็จ');
    })
    .finally(function() { if (btn) btn.disabled = false; });
  });
}

