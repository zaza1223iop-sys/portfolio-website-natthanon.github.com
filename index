        if (msg) { msg.textContent = '✅ อัปโหลดไป Drive สำเร็จ'; msg.style.color = '#3B6D11'; }
        showToast('อัปโหลดไป Drive สำเร็จ');
      } else {
        var errMsg = (result && result.error) ? result.error : (result && result.message) ? result.message : 'ไม่พบการตอบกลับที่ถูกต้อง';
        if (msg) { msg.textContent = '❌ อัปโหลดไม่สำเร็จ: ' + errMsg; msg.style.color = '#c0392b'; }
        showToast('อัปโหลดไป Drive ไม่สำเร็จ');
      }
    })
    .catch(function(err) {
      if (msg) { msg.textContent = '❌ เกิดข้อผิดพลาด: ' + err.message; msg.style.color = '#c0392b'; }
      showToast('อัปโหลดไป Drive ไม่สำเร็จ');
    })
    .finally(function() {
      if (btn) btn.disabled = false;
    });
  });
}

// แปลง Google Drive URL หลายรูปแบบให้เป็น direct image URL
function parseDriveUrl(url) {
  url = url.trim();
  var id = null;
  var m = url.match(/\/file\/d\/([a-zA-Z0-9_-]{10,})/);
  if (m) id = m[1];
  if (!id) { m = url.match(/[?&]id=([a-zA-Z0-9_-]{10,})/); if (m) id = m[1]; }
  if (!id) { m = url.match(/\/d\/([a-zA-Z0-9_-]{10,})/); if (m) id = m[1]; }
  if (!id) return null;
  return 'https://drive.google.com/thumbnail?id=' + id + '&sz=w800';
}

