  font-size:13px;text-align:center;display:none;
}
.ocr-status.loading{background:#EFF6FF;color:#1D4ED8;border:1px solid #BFDBFE;}
.ocr-status.success{background:#F0FDF4;color:#166534;border:1px solid #BBF7D0;}
.ocr-status.error{background:#FEF2F2;color:#991B1B;border:1px solid #FECACA;}

.ocr-result-section{
