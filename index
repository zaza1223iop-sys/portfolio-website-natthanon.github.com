  backdrop-filter: blur(4px);
  color: #fff;
  border: 1.5px solid rgba(255,255,255,0.25);
  border-radius: 20px;
  padding: 5px 12px;
  font-size: 12px;
  font-weight: 600;
  cursor: pointer;
