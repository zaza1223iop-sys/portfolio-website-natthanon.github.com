function closeModal(){document.getElementById('cert-modal').classList.remove('show');}

function editCert(id){
  var c=db.find(function(x){return x.id===id;});if(!c)return;
  closeModal();
  populateForm();
  // ใส่ข้อมูลเดิมลงฟอร์ม
  document.getElementById('f-edit-id').value=id;
  document.getElementById('f-name').value=c.name||'';
  document.getElementById('f-date').value=c.date||'';
  document.getElementById('f-org').value=c.org||'';
  document.getElementById('f-note').value=c.note||'';
  // fill link fields
  var fv=document.getElementById('f-video-url');if(fv)fv.value=c.videoUrl||'';
  var fg=document.getElementById('f-github-url');if(fg)fg.value=c.githubUrl||'';
  var fd=document.getElementById('f-demo-url');if(fd)fd.value=c.demoUrl||'';
  // select fields
  var selType=document.getElementById('f-type');
  var selLevel=document.getElementById('f-level');
  var selAward=document.getElementById('f-award');
  for(var i=0;i<selType.options.length;i++){if(selType.options[i].value===c.type){selType.selectedIndex=i;break;}}
  for(var i=0;i<selLevel.options.length;i++){if(selLevel.options[i].value===c.level){selLevel.selectedIndex=i;break;}}
  for(var i=0;i<selAward.options.length;i++){if(selAward.options[i].value===c.award){selAward.selectedIndex=i;break;}}
  updateScorePreview();
  // รูปภาพเดิม
  if(c.image){
    var prev=document.getElementById('f-preview');
    prev.src=c.image; prev.style.display='block';
    var cb=document.getElementById('f-img-clear-btn');if(cb)cb.style.display='inline-flex';
    var hint=document.getElementById('f-img-size-hint');
    if(c.image.startsWith('https://drive.google.com')){
      // Drive URL
      prev.dataset.driveUrl = c.image;
      if(hint){hint.textContent='🔗 ลิงก์ Google Drive (ไม่กินพื้นที่)';hint.style.color='#185FA5';}
      // switch to drive tab and fill input
      switchImgTab('drive');
      var driveInp=document.getElementById('f-drive-url');
      // ถอด FILE_ID กลับเป็น URL เพื่อแสดงใน input
      var fm=c.image.match(/[?&]id=([a-zA-Z0-9_-]{10,})/);
      if(fm && driveInp) driveInp.value='https://drive.google.com/file/d/'+fm[1]+'/view';
    } else {
      prev.dataset.driveUrl = '';
      if(hint){var sk=Math.round(c.image.length*0.75/1024);hint.textContent='📦 ขนาดรูปปัจจุบัน: '+sk+' KB';hint.style.color=sk>80?'#c0392b':'#3B6D11';}
    }
