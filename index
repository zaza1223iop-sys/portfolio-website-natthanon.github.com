var _restoreData = null;

function doBackup() {
  var cfg = loadSiteSettings();
  var payload = {
    version: 1,
    exportedAt: new Date().toISOString(),
    db: db,
    config: { types: C.types, levels: C.levels, awards: C.awards, scores: C.scores },
    site: { orgName: cfg.orgName, subtitle: cfg.subtitle, color: cfg.color }
  };
  var json = JSON.stringify(payload, null, 2);
  var blob = new Blob([json], { type: 'application/json' });
  var a = document.createElement('a');
  var dateStr = new Date().toISOString().slice(0,10);
  a.href = URL.createObjectURL(blob);
  a.download = 'portfolio-backup-' + dateStr + '.json';
  a.click();
  URL.revokeObjectURL(a.href);
  document.getElementById('backup-info').textContent =
    'Backup ' + db.length + ' รายการ — ' + dateStr;
  showToast('ดาวน์โหลด Backup เรียบร้อยแล้ว');
}

function sendBackupToAppsScript() {
  var cfg = loadSiteSettings();
  var url = (cfg.appsScriptUrl || '').trim();
  var dest = document.getElementById('backup-script-info');
  if (!url) {
    showToast('กรุณาตั้งค่า Apps Script URL ในเมนู ตั้งค่าระบบ/หน้าบ้าน ก่อน');
    if (dest) dest.textContent = '❌ ยังไม่ได้ตั้งค่า Apps Script URL';
    return;
  }
  var payload = {
    version: 1,
    exportedAt: new Date().toISOString(),
    db: db,
    config: { types: C.types, levels: C.levels, awards: C.awards, scores: C.scores },
    site: { orgName: cfg.orgName, subtitle: cfg.subtitle, color: cfg.color }
  };
  if (dest) { dest.textContent = '⏳ ส่ง Backup ไป Apps Script...'; dest.style.color = 'var(--color-text-secondary)'; }
  fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  })
  .then(function(res){ return res.json ? res.json() : Promise.resolve({}); })
  .then(function(result) {
    if (result && (result.success || result.fileUrl || result.driveUrl)) {
      var msg = 'ส่ง Backup ไป Apps Script สำเร็จ';
      if (result.fileUrl) msg += ' | URL: ' + result.fileUrl;
      if (result.driveUrl) msg += ' | Drive: ' + result.driveUrl;
      showToast(msg);
      if (dest) { dest.textContent = '✅ ส่ง Backup สำเร็จ'; dest.style.color = '#3B6D11'; }
    } else {
      var errMsg = (result && result.message) ? result.message : 'ไม่พบการตอบกลับที่ถูกต้อง';
      showToast('ส่ง Backup ไม่สำเร็จ');
      if (dest) { dest.textContent = '❌ ไม่สำเร็จ: ' + errMsg; dest.style.color = '#c0392b'; }
    }
  })
  .catch(function(err) {
    showToast('ส่ง Backup ไม่สำเร็จ');
    if (dest) { dest.textContent = '❌ เกิดข้อผิดพลาด: ' + err.message; dest.style.color = '#c0392b'; }
  });
}

function doRestore(input) {
  var file = input.files[0]; if (!file) return;
  var reader = new FileReader();
  reader.onload = function(e) {
    try {
      var data = JSON.parse(e.target.result);
      if (!data.db || !Array.isArray(data.db)) throw new Error('ไฟล์ไม่ถูกต้อง');
      _restoreData = data;
      var preview = document.getElementById('restore-preview');
      var text = document.getElementById('restore-preview-text');
      var exported = data.exportedAt ? new Date(data.exportedAt).toLocaleDateString('th-TH') : 'ไม่ทราบวันที่';
      text.innerHTML =
        'ไฟล์ Backup วันที่ <strong>' + exported + '</strong><br>' +
        'จำนวนเกียรติบัตร: <strong>' + data.db.length + ' รายการ</strong><br>' +
        '<span style="color:#c0392b;font-size:12px">⚠️ ข้อมูลปัจจุบัน ' + db.length + ' รายการจะถูกแทนที่ทั้งหมด</span>';
      preview.style.display = 'block';
      document.getElementById('restore-info').textContent = 'เลือก: ' + file.name;
    } catch(err) {
      showToast('ไฟล์ไม่ถูกต้อง กรุณาใช้ไฟล์ Backup จากระบบนี้เท่านั้น');
      input.value = '';
    }
  };
  reader.readAsText(file);
}

function confirmRestore() {
  if (!_restoreData) return;
  // restore db
  db = _restoreData.db;
  saveDB();
  // restore config
  if (_restoreData.config) {
    C.types  = _restoreData.config.types  || C.types;
    C.levels = _restoreData.config.levels || C.levels;
    C.awards = _restoreData.config.awards || C.awards;
    C.scores = _restoreData.config.scores || C.scores;
    saveCfg();
  }
  // restore site settings (ยกเว้น PIN และโลโก้ — ไม่เก็บในไฟล์ backup เพื่อความปลอดภัย)
  if (_restoreData.site) {
    var cfg = loadSiteSettings();
    cfg.orgName  = _restoreData.site.orgName  || cfg.orgName;
    cfg.subtitle = _restoreData.site.subtitle || cfg.subtitle;
    cfg.color    = _restoreData.site.color    || cfg.color;
    saveSiteSettings(cfg);
    siteConf = cfg;
  }
  _restoreData = null;
  cancelRestore();
  renderDashboard();
  showToast('Restore สำเร็จ! โหลดข้อมูล ' + db.length + ' รายการแล้ว');
  navigate('dashboard');
}

function cancelRestore() {
  _restoreData = null;
  document.getElementById('restore-preview').style.display = 'none';
  document.getElementById('restore-file').value = '';
  document.getElementById('restore-info').textContent = '—';
}

