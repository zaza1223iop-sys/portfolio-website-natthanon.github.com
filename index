<!-- ===== OCR SCAN MODAL ===== -->
<div id="ocr-modal">
  <div class="ocr-box">
    <div class="ocr-header">
      <div class="ocr-header-icon">📷</div>
      <div>
        <div class="ocr-header-title">สแกนเกียรติบัตร OCR</div>
        <div class="ocr-header-sub">อัปโหลดรูปเกียรติบัตร → OCR อ่านข้อความ → ค้นหาผลงาน</div>
      </div>
      <button class="ocr-close" onclick="closeOcrModal()"><i class="ti ti-x"></i></button>
    </div>
    <div class="ocr-body">

      <!-- Drop Zone -->
      <div class="ocr-drop-zone" id="ocr-drop-zone"
        onclick="document.getElementById('ocr-file-input').click()"
        ondragover="event.preventDefault();this.classList.add('drag-over')"
        ondragleave="this.classList.remove('drag-over')"
        ondrop="handleOcrDrop(event)">
        <span class="ocr-drop-icon">📄</span>
        <div class="ocr-drop-title">ถ่าย / อัปโหลดรูปเกียรติบัตร</div>
        <div class="ocr-drop-sub">คลิกหรือลากรูปมาวางที่นี่ · รองรับ JPG, PNG</div>
      </div>
      <input type="file" id="ocr-file-input" accept="image/*" capture="environment" style="display:none" onchange="onOcrFileChange(this)">

      <!-- Preview -->
      <div class="ocr-preview-wrap" id="ocr-preview-wrap">
        <img id="ocr-preview-img" class="ocr-preview-img" src="" alt="preview">
        <button class="ocr-preview-remove" onclick="clearOcrImage()" title="ลบรูป"><i class="ti ti-x"></i></button>
      </div>

      <!-- Info bar -->
      <div style="margin-top:12px;background:#EFF6FF;border:1px solid #BFDBFE;border-radius:10px;padding:10px 13px;font-size:12px;color:#1D4ED8;display:flex;align-items:flex-start;gap:7px">
        <i class="ti ti-info-circle" style="font-size:15px;flex-shrink:0;margin-top:1px"></i>
        <div>ใช้ <b>OCR.space API</b> — ฟรี ไม่ต้อง Key · รองรับภาษาไทย · ส่งรูปไป ocr.space แล้วรับข้อความกลับมา</div>
      </div>

      <!-- Scan Button -->
      <button class="ocr-scan-btn" id="ocr-scan-btn" onclick="runOcrScan()" disabled>
        <div class="ocr-spinner" id="ocr-spinner"></div>
        <i class="ti ti-scan" id="ocr-btn-icon"></i>
        <span id="ocr-btn-label">🔍 สแกนและค้นหา</span>
      </button>

      <!-- Status -->
      <div class="ocr-status" id="ocr-status"></div>

      <!-- Result Section -->
      <div class="ocr-result-section" id="ocr-result-section">

        <!-- Raw OCR text toggle -->
        <div style="margin-bottom:10px">
          <button onclick="toggleOcrRaw()" style="font-size:11px;background:none;border:1px solid var(--color-border-tertiary);border-radius:6px;padding:4px 10px;cursor:pointer;color:var(--color-text-secondary);font-family:var(--font-sans)" id="ocr-raw-toggle">📄 ดูข้อความดิบจาก OCR</button>
          <div id="ocr-raw-box" style="display:none;margin-top:8px;background:var(--color-background-secondary);border:1px solid var(--color-border-tertiary);border-radius:8px;padding:10px;font-size:11px;font-family:monospace;color:var(--color-text-secondary);max-height:120px;overflow-y:auto;white-space:pre-wrap;word-break:break-all"></div>
        </div>

        <!-- Extracted Info -->
        <div style="font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:0.05em;color:var(--color-text-tertiary);margin-bottom:8px;display:flex;align-items:center;gap:5px">
          <i class="ti ti-file-text"></i> ข้อมูลที่ดึงได้จากรูป
        </div>
        <div class="ocr-extracted-info" id="ocr-extracted-info"></div>

        <!-- Matched Records -->
        <div class="ocr-match-section">
          <div class="ocr-match-label">
            <i class="ti ti-search"></i> ผลงานที่ตรงกัน
            <span id="ocr-match-count" style="background:#FFF8E1;color:#7B5E00;border-radius:20px;padding:1px 8px;font-weight:700"></span>
          </div>
          <div id="ocr-match-list"></div>
        </div>

      </div>
    </div>
  </div>
</div>
<!-- ===== END OCR MODAL ===== -->

