// ===== ตัวแปร state =====
var _syncStatus = 'idle'; // 'idle' | 'loading' | 'saving' | 'error'
var _lastSyncTime = null;

// ===== ดึง Apps Script URL จาก settings =====
function getAppsScriptUrl() {
  try {
    var cfg = loadSiteSettings();
    return (cfg.appsScriptUrl || '').trim();
  } catch(e) { return ''; }
}
function getAppsScriptUploadUrl() {
  try {
    var cfg = loadSiteSettings();
    return (cfg.appsScriptUploadUrl || '').trim();
  } catch(e) { return ''; }
}

// ===== แสดง sync indicator =====
function showSyncIndicator(status, msg) {
  _syncStatus = status;
  var el = document.getElementById('sync-indicator');
  if (!el) return;
  var icons = { loading: '⏳', ok: '✅', error: '❌', idle: '☁️' };
  el.textContent = (icons[status] || '☁️') + ' ' + (msg || '');
  el.style.color = status === 'error' ? '#c0392b' : status === 'ok' ? '#3B6D11' : 'var(--color-text-secondary)';
  if (status === 'ok') setTimeout(function(){ if (el) el.textContent = '☁️ ซิงค์แล้ว'; }, 3000);
}

// ===== โหลดข้อมูลทั้งหมดจาก Sheets เมื่อเปิดหน้า =====
function loadFromSheets(callback) {
  var url = getAppsScriptUrl();
  if (!url) {
    // ไม่มี URL → ใช้ localStorage ปกติ
    if (callback) callback(false);
    return;
  }

  showSyncIndicator('loading', 'กำลังโหลดข้อมูลจาก Sheets...');

  fetch(url + '?action=getData', { method: 'GET' })
    .then(function(res) { return res.json(); })
    .then(function(result) {
      if (result && result.success) {
        // --- เกียรติบัตร ---
        if (result.db && Array.isArray(result.db) && result.db.length > 0) {
          db = result.db;
          saveDB(); // sync กลับ localStorage ด้วย
        }
        // --- config ---
        if (result.config) {
          if (result.config.types  && result.config.types.length)  C.types  = result.config.types;
          if (result.config.levels && result.config.levels.length) C.levels = result.config.levels;
          if (result.config.awards && result.config.awards.length) C.awards = result.config.awards;
          if (result.config.scores && Object.keys(result.config.scores).length) C.scores = result.config.scores;
          saveCfg();
        }
        // --- site settings (ยกเว้น logoData และ pin — ไม่บันทึกใน Sheets) ---
        if (result.site) {
          var localCfg = loadSiteSettings();
          var merged = Object.assign({}, localCfg);
          Object.keys(result.site).forEach(function(k) {
            if (k !== 'logoData' && k !== 'pin') merged[k] = result.site[k];
          });
          saveSiteSettings(merged);
          siteConf = merged;
        }
        // --- ebooks ---
        if (result.ebooks && Array.isArray(result.ebooks)) {
          ebookDB = result.ebooks;
          saveEbookDB();
        }
        // --- popup ---
        if (result.popup && result.popup.title) {
          savePopupSettings(result.popup);
        }

        _lastSyncTime = new Date();
        showSyncIndicator('ok', 'โหลดข้อมูลสำเร็จ');
        // Re-render หน้าที่แสดงอยู่
        renderDashboard();
        renderPublic && renderPublic();
        showToast('☁️ โหลดข้อมูลจาก Google Sheets สำเร็จ — ' + db.length + ' รายการ');
        if (callback) callback(true);
      } else {
        showSyncIndicator('error', 'โหลดไม่สำเร็จ');
        showToast('❌ โหลดจาก Sheets ไม่สำเร็จ: ' + (result.message || 'unknown error'));
        if (callback) callback(false);
      }
    })
    .catch(function(err) {
      showSyncIndicator('error', 'ไม่สามารถเชื่อมต่อได้');
      showToast('❌ เชื่อมต่อ Apps Script ไม่ได้: ' + err.message);
      if (callback) callback(false);
    });
}

// ===== บันทึกข้อมูลทั้งหมดไป Sheets =====
function saveAllToSheets(callback) {
  var url = getAppsScriptUrl();
  if (!url) {
    if (callback) callback(false);
    return;
  }

  showSyncIndicator('loading', 'กำลังบันทึกไป Sheets...');

  var payload = {
    action: 'saveAll',
    exportedAt: new Date().toISOString(),
    db: db,
    config: { types: C.types, levels: C.levels, awards: C.awards, scores: C.scores },
    site: (function(){
      var s = loadSiteSettings();
      // ไม่ส่ง logoData (base64 ใหญ่เกิน)
      var out = {};
      Object.keys(s).forEach(function(k){ if (k !== 'logoData') out[k] = s[k]; });
      return out;
    })(),
    ebooks: ebookDB || []
  };

  fetch(url, {
    method: 'POST',
    headers: { 'Content-Type': 'application/json' },
    body: JSON.stringify(payload)
  })
  .then(function(res) { return res.json(); })
  .then(function(result) {
    if (result && result.success) {
      _lastSyncTime = new Date();
      showSyncIndicator('ok', 'บันทึกสำเร็จ');
      showToast('☁️ บันทึกข้อมูลไป Google Sheets สำเร็จ');
      if (callback) callback(true);
    } else {
      showSyncIndicator('error', 'บันทึกไม่สำเร็จ');
      showToast('❌ บันทึกไป Sheets ไม่สำเร็จ: ' + (result.message || ''));
      if (callback) callback(false);
    }
  })
  .catch(function(err) {
    showSyncIndicator('error', 'บันทึกไม่ได้');
    showToast('❌ บันทึกไป Sheets ไม่ได้: ' + err.message);
    if (callback) callback(false);
  });
}

