}
.ocr-preview-remove{
  position:absolute;top:7px;right:7px;
  width:26px;height:26px;border-radius:50%;
  background:rgba(192,57,43,0.85);color:#fff;border:none;
  font-size:13px;cursor:pointer;display:flex;align-items:center;justify-content:center;
}
.ocr-scan-btn{
  width:100%;padding:13px;margin-top:14px;
  background:linear-gradient(135deg,#1a2744,#2d3f6b);
  border:1.5px solid rgba(232,184,75,0.35);
  border-radius:12px;color:#E8B84B;
  font-size:14px;font-weight:700;cursor:pointer;
  display:flex;align-items:center;justify-content:center;gap:8px;
  transition:all 0.18s;font-family:var(--font-sans);
}
.ocr-scan-btn:hover{border-color:rgba(232,184,75,0.7);box-shadow:0 4px 18px rgba(232,184,75,0.2);}
.ocr-scan-btn:disabled{opacity:0.45;cursor:not-allowed;}
.ocr-spinner{
  width:18px;height:18px;border:2.5px solid rgba(232,184,75,0.3);
  border-top-color:#E8B84B;border-radius:50%;
