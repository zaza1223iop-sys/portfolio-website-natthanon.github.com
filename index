// ===== เพิ่ม sync indicator + ปุ่มในหน้าจอ =====
function injectSyncUI() {
  // เพิ่ม indicator ใน topbar
  var topbar = document.querySelector('.topbar');
  if (topbar && !document.getElementById('sync-indicator')) {
    var ind = document.createElement('span');
    ind.id = 'sync-indicator';
    ind.style.cssText = 'font-size:12px;color:var(--color-text-tertiary);cursor:pointer;padding:4px 8px;border-radius:6px;border:0.5px solid var(--color-border-tertiary);background:var(--color-background-secondary)';
    ind.title = 'คลิกเพื่อ Sync ข้อมูล';
    ind.textContent = '☁️ Sheets';
    ind.onclick = function() {
      showSyncMenu();
    };
    topbar.appendChild(ind);
  }
}

function showSyncMenu() {
  var url = getAppsScriptUrl();
  if (!url) {
    showToast('⚠️ ยังไม่ได้ตั้งค่า Apps Script URL — ไปที่ ตั้งค่าระบบ/หน้าบ้าน');
    return;
  }
  var menu = document.createElement('div');
  menu.id = 'sync-menu-popup';
  menu.style.cssText = 'position:fixed;top:60px;right:20px;z-index:9999;background:#fff;border:0.5px solid var(--color-border-tertiary);border-radius:12px;padding:12px;box-shadow:0 8px 24px rgba(0,0,0,0.15);min-width:200px';
  menu.innerHTML =
    '<div style="font-size:12px;font-weight:700;color:var(--color-text-primary);margin-bottom:8px">☁️ Google Sheets Sync</div>'
    + '<button onclick="syncFromSheets();document.getElementById(\'sync-menu-popup\').remove()" class="btn btn-navy" style="width:100%;font-size:12px;margin-bottom:6px;padding:8px"><i class="ti ti-download"></i> โหลดจาก Sheets</button>'
    + '<button onclick="syncToSheets();document.getElementById(\'sync-menu-popup\').remove()" class="btn btn-gold" style="width:100%;font-size:12px;padding:8px"><i class="ti ti-upload"></i> บันทึกไป Sheets</button>'
    + ((_lastSyncTime) ? '<div style="font-size:10px;color:var(--color-text-tertiary);margin-top:8px;text-align:center">ซิงค์ล่าสุด: '+_lastSyncTime.toLocaleTimeString('th-TH')+'</div>' : '')
    + '<div style="border-top:0.5px solid var(--color-border-tertiary);margin-top:8px;padding-top:8px"><button onclick="document.getElementById(\'sync-menu-popup\').remove()" style="font-size:11px;color:var(--color-text-tertiary);background:none;border:none;cursor:pointer;width:100%">ปิด</button></div>';
  document.body.appendChild(menu);
  // ปิดเมื่อคลิกข้างนอก
  setTimeout(function() {
    document.addEventListener('click', function closeSyncMenu(ev) {
      var m = document.getElementById('sync-menu-popup');
      if (m && !m.contains(ev.target)) { m.remove(); document.removeEventListener('click', closeSyncMenu); }
    });
  }, 50);
}

