function parseEbookCoverUrl(url) {
  url = (url || '').trim();
  if (!url) return '';
  // Google Drive
  var m = url.match(/\/file\/d\/([a-zA-Z0-9_-]{10,})/);
  if (!m) m = url.match(/[?&]id=([a-zA-Z0-9_-]{10,})/);
  if (m) return 'https://drive.google.com/thumbnail?id=' + m[1] + '&sz=w400';
  return url;
}

function loadEbookCoverPreview() {
  var url = parseEbookCoverUrl(document.getElementById('eb-cover-url').value);
  if (!url) { showToast('กรุณากรอก URL รูปก่อน'); return; }
  var prev = document.getElementById('eb-cover-preview');
  prev.onerror = function(){ showToast('โหลดรูปไม่ได้ ตรวจสอบ URL และสิทธิ์การแชร์'); prev.style.display='none'; prev.onerror=null; };
  prev.onload = function(){ prev.onload=null; document.getElementById('eb-cover-clear-btn').style.display='inline-flex'; };
  prev.src = url; prev.style.display = 'block'; prev.dataset.coverData = url;
}

