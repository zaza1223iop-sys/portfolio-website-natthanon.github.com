}
.ai-result-copy:hover { background: #1a2744; color: #fff; border-color: #1a2744; }
.ai-apply-btn {
  width: 100%; padding: 10px;
  background: #B8860B; color: #fff;
  border: none; border-radius: 10px;
  font-size: 13px; font-weight: 700; cursor: pointer;
  display: flex; align-items: center; justify-content: center; gap: 7px;
  transition: opacity 0.12s; font-family: var(--font-sans); margin-top: 6px;
}
.ai-apply-btn:hover { opacity: 0.88; }
.ai-highlights-grid {
  display: flex; flex-wrap: wrap; gap: 6px; margin-top: 4px;
}
.ai-highlight-tag {
  font-size: 12px; padding: 4px 11px; border-radius: 20px;
  background: #FFF8E1; color: #7B5E00;
  border: 0.5px solid rgba(184,134,11,0.3); font-weight: 600;
}
/* ===== THEME SYSTEM ===== */
:root {
  --theme-primary: #1a2744;
  --theme-primary-light: #2d3f6b;
  --theme-accent: #E8B84B;
  --theme-accent-dark: #B8860B;
  --theme-sidebar-bg: #1a2744;
  --theme-sidebar-text: rgba(255,255,255,0.55);
  --theme-sidebar-active-bg: rgba(232,184,75,0.1);
  --theme-sidebar-active-text: #E8B84B;
  --theme-sidebar-active-border: #E8B84B;
  --theme-card-accent: #B8860B;
  --theme-hero-grad: linear-gradient(135deg,#1a2744 0%,#2d3f6b 100%);
  --theme-stat-gold-bg: #FFF8E1;
  --theme-stat-gold-text: #7B5E00;
  --theme-badge-bg: #FFF8E1;
  --theme-badge-text: #7B5E00;
  --theme-btn-navy-bg: #1a2744;
  --theme-btn-gold-bg: #B8860B;
}

/* --- Minimal Theme --- */
body.theme-minimal {
  --theme-primary: #374151;
  --theme-primary-light: #4B5563;
  --theme-accent: #6B7280;
  --theme-accent-dark: #374151;
  --theme-sidebar-bg: #111827;
  --theme-sidebar-text: rgba(255,255,255,0.5);
  --theme-sidebar-active-bg: rgba(255,255,255,0.08);
  --theme-sidebar-active-text: #ffffff;
  --theme-sidebar-active-border: #ffffff;
  --theme-card-accent: #374151;
  --theme-hero-grad: linear-gradient(135deg,#111827 0%,#374151 100%);
  --theme-stat-gold-bg: #F3F4F6;
  --theme-stat-gold-text: #111827;
  --theme-badge-bg: #F3F4F6;
  --theme-badge-text: #374151;
  --theme-btn-navy-bg: #111827;
  --theme-btn-gold-bg: #374151;
}

/* --- Tech Theme --- */
body.theme-tech {
  --theme-primary: #0f172a;
  --theme-primary-light: #1e3a5f;
  --theme-accent: #38bdf8;
  --theme-accent-dark: #0284c7;
  --theme-sidebar-bg: #0f172a;
  --theme-sidebar-text: rgba(148,215,255,0.5);
  --theme-sidebar-active-bg: rgba(56,189,248,0.12);
  --theme-sidebar-active-text: #38bdf8;
  --theme-sidebar-active-border: #38bdf8;
  --theme-card-accent: #0284c7;
  --theme-hero-grad: linear-gradient(135deg,#0f172a 0%,#0c4a6e 50%,#0f172a 100%);
  --theme-stat-gold-bg: #e0f2fe;
  --theme-stat-gold-text: #0c4a6e;
  --theme-badge-bg: #e0f2fe;
  --theme-badge-text: #0284c7;
  --theme-btn-navy-bg: #0f172a;
  --theme-btn-gold-bg: #0284c7;
}

/* --- Creative Theme --- */
body.theme-creative {
  --theme-primary: #7c3aed;
  --theme-primary-light: #a855f7;
  --theme-accent: #f59e0b;
  --theme-accent-dark: #d97706;
  --theme-sidebar-bg: #1e1b4b;
  --theme-sidebar-text: rgba(221,214,254,0.55);
  --theme-sidebar-active-bg: rgba(245,158,11,0.12);
  --theme-sidebar-active-text: #f59e0b;
  --theme-sidebar-active-border: #f59e0b;
  --theme-card-accent: #7c3aed;
  --theme-hero-grad: linear-gradient(135deg,#1e1b4b 0%,#7c3aed 60%,#a855f7 100%);
  --theme-stat-gold-bg: #fdf4ff;
  --theme-stat-gold-text: #6b21a8;
  --theme-badge-bg: #fef3c7;
  --theme-badge-text: #92400e;
  --theme-btn-navy-bg: #4c1d95;
  --theme-btn-gold-bg: #d97706;
}

/* Apply CSS vars to components */
.sidebar { background: var(--theme-sidebar-bg) !important; }
.nav-item { color: var(--theme-sidebar-text) !important; }
.nav-item.active {
  color: var(--theme-sidebar-active-text) !important;
  background: var(--theme-sidebar-active-bg) !important;
  border-left-color: var(--theme-sidebar-active-border) !important;
}
.nav-item:hover { color: #fff !important; }
.logo-avatar { background: var(--theme-accent) !important; color: var(--theme-sidebar-bg) !important; }
.card-title i { color: var(--theme-card-accent) !important; }
.stat-card.gold { background: var(--theme-stat-gold-bg) !important; }
.stat-card.gold .stat-num { color: var(--theme-stat-gold-text) !important; }
.cert-score { background: var(--theme-badge-bg) !important; color: var(--theme-badge-text) !important; }
.btn-navy { background: var(--theme-btn-navy-bg) !important; color: #fff !important; }
.btn-gold { background: var(--theme-btn-gold-bg) !important; color: #fff !important; }
.bar-fill, .rank-bar-fill { background: var(--theme-accent-dark) !important; }
.rank-score { color: var(--theme-stat-gold-text) !important; }
.score-preview, .score-row-pts { color: var(--theme-stat-gold-text) !important; }
.ai-generate-btn { background: linear-gradient(135deg, var(--theme-primary), var(--theme-primary-light)) !important; color: var(--theme-accent) !important; border-color: rgba(255,255,255,0.15) !important; }
.ai-writer-trigger-row { background: linear-gradient(135deg, var(--theme-primary) 0%, var(--theme-primary-light) 100%) !important; border-color: rgba(255,255,255,0.15) !important; }
.ai-writer-label-title { color: var(--theme-accent) !important; }
.ai-lang-btn.active { background: var(--theme-primary) !important; color: var(--theme-accent) !important; }
.pub-header, .pub-hero { background: var(--theme-hero-grad) !important; }
.pub-stat-pill .num { color: var(--theme-accent) !important; }

/* Tech Theme: monospace feel */
body.theme-tech .cert-name, body.theme-tech .card-title { letter-spacing: -0.01em; }
body.theme-tech .sidebar { border-right: 1px solid rgba(56,189,248,0.15); }
body.theme-tech .nav-sep { background: rgba(56,189,248,0.12) !important; }

/* Creative Theme: gradient cards */
body.theme-creative .cert-thumb { background: linear-gradient(135deg, #1e1b4b, #7c3aed) !important; }
body.theme-creative .card { border-color: rgba(124,58,237,0.15) !important; }
body.theme-creative .nav-sep { background: rgba(245,158,11,0.15) !important; }
body.theme-creative .logo-name { background: linear-gradient(90deg, #f59e0b, #a855f7); -webkit-background-clip: text; -webkit-text-fill-color: transparent; }

/* Minimal Theme: ultra clean */
body.theme-minimal .card { border-radius: 6px !important; border-color: #e5e7eb !important; }
body.theme-minimal .cert-card { border-radius: 6px !important; }
body.theme-minimal .stat-card { border-radius: 6px !important; }
body.theme-minimal .btn { border-radius: 4px !important; }
body.theme-minimal .nav-sep { background: rgba(255,255,255,0.08) !important; }

/* Theme picker widget */
.theme-picker-grid {
  display: grid; grid-template-columns: repeat(3, 1fr); gap: 10px; margin-top: 12px;
}
.theme-card {
  border: 2px solid var(--color-border-tertiary);
  border-radius: 12px; overflow: hidden; cursor: pointer;
  transition: all 0.18s; position: relative;
}
.theme-card:hover { transform: translateY(-2px); box-shadow: 0 6px 20px rgba(0,0,0,0.12); }
.theme-card.selected { border-color: #B8860B; box-shadow: 0 0 0 3px rgba(184,134,11,0.2); }
.theme-card.selected::after {
  content: '✓'; position: absolute; top: 6px; right: 8px;
  background: #B8860B; color: #fff; border-radius: 50%; width: 18px; height: 18px;
  display: flex; align-items: center; justify-content: center; font-size: 11px; font-weight: 700;
}
.theme-preview {
  height: 60px; display: flex;
}
.theme-preview-sidebar {
  width: 28%; display: flex; flex-direction: column; gap: 4px; padding: 6px 5px;
}
.theme-preview-dot {
  height: 5px; border-radius: 3px; opacity: 0.6;
}
.theme-preview-dot.active { opacity: 1; width: 80%; }
.theme-preview-main { flex: 1; padding: 6px; display: flex; flex-direction: column; gap: 4px; }
.theme-preview-bar { height: 5px; border-radius: 3px; background: #e5e7eb; }
.theme-preview-bar.accent { width: 60%; }
.theme-label {
  padding: 6px 10px 8px; font-size: 12px; font-weight: 700;
  color: var(--color-text-primary); text-align: center;
}
.theme-label small { display: block; font-size: 10px; font-weight: 400; color: var(--color-text-tertiary); margin-top: 1px; }
/* ===== END THEME SYSTEM ===== */
#page-resume .form-input[type=url],
#page-resume textarea.form-input { font-size:13px; }
#page-resume #rv-result-content { font-family: 'Prompt', monospace; }
